@model List<RolePermissionViewModel>
@{
    ViewData["Title"] = "角色管理";
}

<div class="mb-3">
    <h4 class="mb-0"><i class="bi bi-shield-lock-fill me-2"></i>角色管理</h4>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle" id="permTable">
        <thead class="table-dark">
            <tr>
                <th class="text-center" style="width:60px">序号</th>
                <th style="width:140px">角色</th>
                <th>权限设置</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
            }
            @foreach (var rp in Model)
            {
                var perms = (rp.Permissions ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).Select(p => p.Trim()).ToHashSet();
                <tr data-role="@rp.Role" data-perms="@rp.Permissions">
                    <td class="text-center">@(i++)</td>
                    <td><strong>@rp.Role</strong></td>
                    <td>
                        <button type="button" class="btn btn-outline-primary btn-sm btn-set-perms">
                            <i class="bi bi-gear me-1"></i>权限
                        </button>
                        <span class="text-muted small ms-2 perm-summary">
                            @{
                                var labels = new List<string>();
                                if (perms.Contains("student_add") || perms.Contains("student_edit") || perms.Contains("student_delete")) labels.Add("学生");
                                if (perms.Contains("teacher_add") || perms.Contains("teacher_edit") || perms.Contains("teacher_delete")) labels.Add("教职工");
                                if (perms.Contains("exam_add") || perms.Contains("exam_edit") || perms.Contains("exam_delete") || perms.Contains("score_input") || perms.Contains("score_view")) labels.Add("成绩");
                                if (perms.Contains("grade_add") || perms.Contains("grade_edit") || perms.Contains("grade_delete") || perms.Contains("grade_set_teacher")) labels.Add("班级");
                                if (labels.Count == 0) { <span>无权限</span> } else { <span>@string.Join("、", labels)</span> }
                            }
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- 权限设置对话框 -->
<div class="modal fade" id="permModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-gear me-2"></i><span id="permModalRole"></span> - 权限设置</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="currentRole" />

                <div class="mb-3">
                    <h6 class="border-bottom pb-2 text-primary"><i class="bi bi-people me-1"></i>学生管理</h6>
                    <div class="row">
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="student_view" id="perm_student_view" />
                                <label class="form-check-label" for="perm_student_view">查看学生</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="student_add" id="perm_student_add" />
                                <label class="form-check-label" for="perm_student_add">新增学生</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="student_edit" id="perm_student_edit" />
                                <label class="form-check-label" for="perm_student_edit">编辑学生</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="student_delete" id="perm_student_delete" />
                                <label class="form-check-label" for="perm_student_delete">删除/转出学生</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <h6 class="border-bottom pb-2 text-success"><i class="bi bi-person-badge me-1"></i>教职工管理</h6>
                    <div class="row">
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="teacher_view" id="perm_teacher_view" />
                                <label class="form-check-label" for="perm_teacher_view">查看教职工</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="teacher_add" id="perm_teacher_add" />
                                <label class="form-check-label" for="perm_teacher_add">新增教职工</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="teacher_edit" id="perm_teacher_edit" />
                                <label class="form-check-label" for="perm_teacher_edit">编辑教职工</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="teacher_delete" id="perm_teacher_delete" />
                                <label class="form-check-label" for="perm_teacher_delete">删除教职工</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <h6 class="border-bottom pb-2 text-warning"><i class="bi bi-file-earmark-text me-1"></i>成绩管理</h6>
                    <div class="row">
                        <div class="col-md-6 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="subject_manage" id="perm_subject_manage" />
                                <label class="form-check-label" for="perm_subject_manage">📋 科目管理</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="exam_add" id="perm_exam_add" />
                                <label class="form-check-label" for="perm_exam_add">📋 考试安排 - 新增</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-1 ps-5">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="exam_edit" id="perm_exam_edit" />
                                <label class="form-check-label" for="perm_exam_edit">考试安排 - 编辑</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-1 ps-5">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="exam_delete" id="perm_exam_delete" />
                                <label class="form-check-label" for="perm_exam_delete">考试安排 - 删除</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="score_input" id="perm_score_input" />
                                <label class="form-check-label" for="perm_score_input">📋 成绩录入</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="score_view" id="perm_score_view" />
                                <label class="form-check-label" for="perm_score_view">📋 成绩分析</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="score_import" id="perm_score_import" />
                                <label class="form-check-label" for="perm_score_import">📋 批量导入</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="ai_settings" id="perm_ai_settings" />
                                <label class="form-check-label" for="perm_ai_settings">📋 AI设置</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <h6 class="border-bottom pb-2 text-info"><i class="bi bi-building me-1"></i>班级管理</h6>
                    <div class="row">
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="grade_add" id="perm_grade_add" />
                                <label class="form-check-label" for="perm_grade_add">新增年级/班级</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="grade_edit" id="perm_grade_edit" />
                                <label class="form-check-label" for="perm_grade_edit">编辑班级</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="grade_delete" id="perm_grade_delete" />
                                <label class="form-check-label" for="perm_grade_delete">删除年级/班级</label>
                            </div>
                        </div>
                        <div class="col-md-4 mb-1">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="grade_set_teacher" id="perm_grade_set_teacher" />
                                <label class="form-check-label" for="perm_grade_set_teacher">设置班主任</label>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="btnSaveRole"><i class="bi bi-check-lg me-1"></i>确定</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 点击"权限"按钮，弹出对话框
        $(document).on('click', '.btn-set-perms', function () {
            var $tr = $(this).closest('tr');
            var role = $tr.data('role');
            var permsStr = $tr.data('perms') || '';

            $('#currentRole').val(role);
            $('#permModalRole').text(role);

            // 解析已有权限并勾选
            var perms = permsStr.split(',').map(function (p) { return p.trim(); });
            $('#permModal .perm-cb').each(function () {
                var p = $(this).data('perm');
                $(this).prop('checked', perms.indexOf(p) >= 0);
            });

            new bootstrap.Modal(document.getElementById('permModal')).show();
        });

        // 对话框"确定"按钮 - 直接保存到数据库
        $('#btnSaveRole').click(function () {
            var role = $('#currentRole').val();

            // 收集勾选的权限
            var checkedPerms = [];
            $('#permModal .perm-cb:checked').each(function () {
                checkedPerms.push($(this).data('perm'));
            });
            var permStr = checkedPerms.join(',');

            var permData = {
                role: role,
                studentView: checkedPerms.indexOf('student_view') >= 0,
                studentAdd: checkedPerms.indexOf('student_add') >= 0,
                studentEdit: checkedPerms.indexOf('student_edit') >= 0,
                studentDelete: checkedPerms.indexOf('student_delete') >= 0,
                teacherView: checkedPerms.indexOf('teacher_view') >= 0,
                teacherAdd: checkedPerms.indexOf('teacher_add') >= 0,
                teacherEdit: checkedPerms.indexOf('teacher_edit') >= 0,
                teacherDelete: checkedPerms.indexOf('teacher_delete') >= 0,
                examAdd: checkedPerms.indexOf('exam_add') >= 0,
                examEdit: checkedPerms.indexOf('exam_edit') >= 0,
                examDelete: checkedPerms.indexOf('exam_delete') >= 0,
                scoreInput: checkedPerms.indexOf('score_input') >= 0,
                scoreView: checkedPerms.indexOf('score_view') >= 0,
                scoreImport: checkedPerms.indexOf('score_import') >= 0,
                aiSettings: checkedPerms.indexOf('ai_settings') >= 0,
                subjectManage: checkedPerms.indexOf('subject_manage') >= 0,
                gradeAdd: checkedPerms.indexOf('grade_add') >= 0,
                gradeEdit: checkedPerms.indexOf('grade_edit') >= 0,
                gradeDelete: checkedPerms.indexOf('grade_delete') >= 0,
                gradeSetTeacher: checkedPerms.indexOf('grade_set_teacher') >= 0
            };

            var btn = $(this);
            var originalText = btn.html();
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>保存中...');

            $.ajax({
                url: '@Url.Action("BatchUpdatePermissions")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify([permData]),
                headers: { 'RequestVerificationToken': $('[name="__RequestVerificationToken"]').first().val() }
            }).done(function (res) {
                if (res.success) {
                    toastr.success(res.message);
                    // 更新表格行
                    var $tr = $('#permTable tbody tr[data-role="' + role + '"]');
                    $tr.data('perms', permStr);
                    var summary = '';
                    if (checkedPerms.some(function (p) { return ['student_view','student_add','student_edit','student_delete'].indexOf(p) >= 0; })) summary += '学生、';
                    if (checkedPerms.some(function (p) { return ['teacher_view','teacher_add','teacher_edit','teacher_delete'].indexOf(p) >= 0; })) summary += '教职工、';
                    if (checkedPerms.some(function (p) { return ['exam_add','exam_edit','exam_delete','score_input','score_view','score_import','ai_settings','subject_manage'].indexOf(p) >= 0; })) summary += '成绩、';
                    if (checkedPerms.some(function (p) { return ['grade_add','grade_edit','grade_delete','grade_set_teacher'].indexOf(p) >= 0; })) summary += '班级、';
                    summary = summary.replace(/、$/, '');
                    $tr.find('.perm-summary').text(summary || '无权限');
                    bootstrap.Modal.getInstance(document.getElementById('permModal')).hide();
                } else {
                    toastr.error(res.message);
                }
            }).fail(function () {
                toastr.error('保存失败，请重试');
            }).always(function () {
                btn.prop('disabled', false).html(originalText);
            });
        });
    </script>
}
