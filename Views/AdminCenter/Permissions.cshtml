@model List<RolePermissionViewModel>
@{
    ViewData["Title"] = "角色管理";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-shield-lock-fill me-2"></i>角色管理</h4>
    <button class="btn btn-primary" id="btnSaveAll"><i class="bi bi-floppy me-1"></i>保存全部</button>
</div>

<div class="alert alert-info py-2 small">
    <i class="bi bi-info-circle me-1"></i>按角色设置权限，系统将自动同步应用到所有拥有该角色的用户。
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle" id="permTable">
        <thead class="table-dark">
            <tr>
                <th class="text-center" style="width:60px">序号</th>
                <th style="width:120px">角色</th>
                <th>权限设置</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
            }
            @foreach (var rp in Model)
            {
                var perms = (rp.Permissions ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries).Select(p => p.Trim()).ToHashSet();
                <tr data-role="@rp.Role">
                    <td class="text-center">@(i++)</td>
                    <td>
                        <strong>@rp.Role</strong>
                    </td>
                    <td>
                        <div class="d-flex flex-wrap gap-3">
                            <label class="form-check-label me-2" style="min-width:130px">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="student_view" checked disabled />
                                <span class="text-muted">查看学生</span>
                            </label>
                            <label class="form-check-label me-2" style="min-width:130px">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="student_add" @(perms.Contains("student_add") ? "checked" : "") />
                                新增学生
                            </label>
                            <label class="form-check-label me-2" style="min-width:130px">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="student_edit" @(perms.Contains("student_edit") ? "checked" : "") />
                                编辑学生
                            </label>
                            <label class="form-check-label me-2" style="min-width:150px">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="student_delete" @(perms.Contains("student_delete") ? "checked" : "") />
                                删除/转出学生
                            </label>
                            <label class="form-check-label me-2" style="min-width:130px">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="teacher_view" checked disabled />
                                <span class="text-muted">查看教职工</span>
                            </label>
                            <label class="form-check-label me-2" style="min-width:130px">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="teacher_add" @(perms.Contains("teacher_add") ? "checked" : "") />
                                新增教职工
                            </label>
                            <label class="form-check-label me-2" style="min-width:130px">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="teacher_edit" @(perms.Contains("teacher_edit") ? "checked" : "") />
                                编辑教职工
                            </label>
                            <label class="form-check-label me-2" style="min-width:130px">
                                <input type="checkbox" class="form-check-input perm-cb" data-perm="teacher_delete" @(perms.Contains("teacher_delete") ? "checked" : "") />
                                删除教职工
                            </label>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $('#btnSaveAll').click(function () {
            var roles = [];
            $('#permTable tbody tr').each(function () {
                var role = $(this).data('role');
                var permData = {
                    role: role,
                    studentAdd: $(this).find('.perm-cb[data-perm="student_add"]').prop('checked'),
                    studentEdit: $(this).find('.perm-cb[data-perm="student_edit"]').prop('checked'),
                    studentDelete: $(this).find('.perm-cb[data-perm="student_delete"]').prop('checked'),
                    teacherAdd: $(this).find('.perm-cb[data-perm="teacher_add"]').prop('checked'),
                    teacherEdit: $(this).find('.perm-cb[data-perm="teacher_edit"]').prop('checked'),
                    teacherDelete: $(this).find('.perm-cb[data-perm="teacher_delete"]').prop('checked')
                };
                roles.push(permData);
            });

            var btn = $(this);
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>保存中...');

            $.ajax({
                url: '@Url.Action("BatchUpdatePermissions")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(roles),
                headers: { 'RequestVerificationToken': $('[name="__RequestVerificationToken"]').first().val() }
            }).done(function (res) {
                if (res.success) { toastr.success(res.message); }
                else { toastr.error(res.message); }
            }).fail(function () {
                toastr.error('保存失败，请重试');
            }).always(function () {
                btn.prop('disabled', false).html('<i class="bi bi-floppy me-1"></i>保存全部');
            });
        });
    </script>
}
