@model List<OperationLog>
@{
    ViewBag.Title = "操作日志";
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;
    var totalCount = (int)ViewBag.TotalCount;
    var todayCount = (int)ViewBag.TodayCount;
    var actionTypes = new[] { "全部", "添加", "编辑", "删除", "导入", "恢复", "发布公告", "编辑公告", "删除公告", "添加年级", "删除年级", "添加班级", "删除班级", "分配班主任", "取消班主任", "创建考试", "编辑考试", "删除考试", "批量转班", "批量毕业", "批量删除" };
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-clock-history me-2"></i>操作日志</h4>
        <div>
            <a asp-action="ExportLogs"
               asp-route-actionType="@ViewBag.FilterActionType"
               asp-route-keyword="@ViewBag.FilterKeyword"
               class="btn btn-success btn-sm">
                <i class="bi bi-file-earmark-excel me-1"></i>导出Excel
            </a>
        </div>
    </div>

    <!-- 统计卡片 -->
    <div class="row g-2 mb-3">
        <div class="col-md-3 col-6">
            <div class="card border-primary h-100 text-center py-2">
                <div class="card-body p-2">
                    <h5 class="mb-0 text-primary">@totalCount</h5>
                    <small class="text-muted">总操作数</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-success h-100 text-center py-2">
                <div class="card-body p-2">
                    <h5 class="mb-0 text-success">@todayCount</h5>
                    <small class="text-muted">今日操作</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-info h-100 text-center py-2">
                <div class="card-body p-2">
                    <h5 class="mb-0 text-info">@currentPage</h5>
                    <small class="text-muted">当前页</small>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card border-secondary h-100 text-center py-2">
                <div class="card-body p-2">
                    <h5 class="mb-0 text-secondary">@totalPages</h5>
                    <small class="text-muted">总页数</small>
                </div>
            </div>
        </div>
    </div>

    <!-- 搜索筛选 -->
    <div class="card bg-light mb-3">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="small text-muted mb-1">操作类型</label>
                    <select name="actionType" class="form-select form-select-sm">
                        @foreach (var at in actionTypes)
                        {
                            <option value="@at" selected="@(ViewBag.FilterActionType == at)">@at</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="small text-muted mb-1">关键词</label>
                    <input type="text" name="keyword" class="form-control form-control-sm" placeholder="操作人/目标/详情" value="@ViewBag.FilterKeyword" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>搜索</button>
                    <a asp-action="OperationLogs" asp-route-actionType="" asp-route-keyword="" class="btn btn-outline-secondary btn-sm">清空</a>
                    <button type="button" class="btn btn-outline-danger btn-sm" id="btnClearAllLogs"><i class="bi bi-trash3 me-1"></i>清空全部日志</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-inbox" style="font-size:3rem;"></i>
                    <p class="mt-2">暂无操作日志</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:50px;">#</th>
                                <th>操作人</th>
                                <th>角色</th>
                                <th>操作类型</th>
                                <th>目标</th>
                                <th>详细信息</th>
                                <th style="width:150px;">IP地址</th>
                                <th style="width:180px;">操作时间</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.Select((item, i) => new { item, i }))
                            {
                                var opClass = log.item.ActionType switch
                                {
                                    "添加" or "导入" or "发布公告" or "分配班主任" => "text-success",
                                    "编辑" or "编辑公告" or "编辑考试" => "text-primary",
                                    "删除" or "彻底删除" or "删除公告" or "删除考试" or "删除年级" or "删除班级" => "text-danger",
                                    "恢复" => "text-warning",
                                    "创建考试" or "添加年级" or "添加班级" => "text-info",
                                    "批量转班" or "批量毕业" or "批量删除" => "text-warning",
                                    "取消班主任" => "text-secondary",
                                    _ => ""
                                };
                                <tr>
                                    <td class="text-muted">@((currentPage - 1) * 20 + log.i + 1)</td>
                                    <td>@log.item.OperatorName</td>
                                    <td><span class="badge bg-secondary">@log.item.OperatorRole</span></td>
                                    <td><span class="@opClass">@log.item.ActionType</span></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(log.item.TargetName))
                                        {
                                            <span>@log.item.TargetName</span>
                                            if (!string.IsNullOrEmpty(log.item.TargetNo))
                                            {
                                                <small class="text-muted ms-1">(@log.item.TargetNo)</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="small text-muted">@log.item.Detail</td>
                                    <td class="small text-monospace text-muted">@log.item.IpAddress</td>
                                    <td class="small text-muted">@log.item.CreateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" href="?page=@(currentPage - 1)&actionType=@ViewBag.FilterActionType&keyword=@ViewBag.FilterKeyword">上一页</a>
                </li>
                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == currentPage ? "active" : "")">
                        <a class="page-link" href="?page=@p&actionType=@ViewBag.FilterActionType&keyword=@ViewBag.FilterKeyword">@p</a>
                    </li>
                }
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="?page=@(currentPage + 1)&actionType=@ViewBag.FilterActionType&keyword=@ViewBag.FilterKeyword">下一页</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
    <script>
        $('#btnClearAllLogs').on('click', function() {
            showConfirm('⚠ 确定清空所有操作日志吗？此操作不可恢复！', function() {
                $.post('@Url.Action("ClearLogs", "AdminCenter")', {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                }).done(function(res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                }).fail(function() {
                    alert('清空失败，请重试');
                });
            });
        });
    </script>
}
