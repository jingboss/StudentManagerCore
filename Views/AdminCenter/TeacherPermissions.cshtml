@model List<Admin>
@{
    ViewData["Title"] = "批量个人中心权限管理";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var isAdmin = role.Trim() == "管理员";
}

@if (!isAdmin)
{
    <div class="alert alert-danger">您没有权限访问此页面</div>
    return;
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0">
        <i class="bi bi-person-gear me-2"></i>批量个人中心权限管理
        <span class="badge bg-secondary ms-2">共 @Model.Count 人</span>
    </h4>
    <div>
        <a asp-action="StudentPermissions" class="btn btn-outline-warning btn-sm me-2">
            <i class="bi bi-people-fill me-1"></i> 切换到学生权限
        </a>
        <button type="button" class="btn btn-success" id="btnSaveAll">
            <i class="bi bi-check2-all me-1"></i> 保存全部修改
        </button>
    </div>
</div>

<div class="alert alert-info d-flex align-items-center">
    <i class="bi bi-info-circle-fill me-2"></i>
    设置班主任在<strong>个人中心</strong>中可以自行修改的信息。管理员拥有所有权限，不在此页面显示。
</div>

<div class="table-responsive" style="overflow-x: auto;">
    <table class="table table-bordered table-hover align-middle text-center" id="permTable" style="font-size:0.85rem; white-space:nowrap;">
        <thead class="table-info">
            <tr>
                <th style="min-width:70px;">姓名</th>
                <th style="min-width:55px;">
                    修改基本信息<br/>
                    <input type="checkbox" class="master-check" data-col="1" title="全选/取消" />
                </th>
                <th style="min-width:55px;">
                    修改手机号<br/>
                    <input type="checkbox" class="master-check" data-col="2" title="全选/取消" />
                </th>
                <th style="min-width:55px;">
                    修改身份证<br/>
                    <input type="checkbox" class="master-check" data-col="3" title="全选/取消" />
                </th>
                <th style="min-width:55px;">
                    修改证书<br/>
                    <input type="checkbox" class="master-check" data-col="4" title="全选/取消" />
                </th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">暂无班主任/教师用户</td>
                </tr>
            }
            @foreach (var teacher in Model)
            {
                var perms = (teacher.Permissions ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries);
                <tr data-id="@teacher.AdminID">
                    <td class="text-start fw-bold">@teacher.RealName</td>
                    <td><input type="checkbox" class="perm-check" data-perm="profile_basic" @(perms.Contains("profile_basic") ? "checked" : "") /></td>
                    <td><input type="checkbox" class="perm-check" data-perm="profile_phone" @(perms.Contains("profile_phone") ? "checked" : "") /></td>
                    <td><input type="checkbox" class="perm-check" data-perm="profile_idcard" @(perms.Contains("profile_idcard") ? "checked" : "") /></td>
                    <td><input type="checkbox" class="perm-check" data-perm="profile_cert" @(perms.Contains("profile_cert") ? "checked" : "") /></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).on('change', '.master-check', function () {
            var colIndex = parseInt($(this).data('col'));
            var isChecked = $(this).prop('checked');
            $('#permTable tbody tr').each(function () {
                $(this).find('td:eq(' + colIndex + ') input.perm-check').prop('checked', isChecked);
            });
        });

        $('#btnSaveAll').on('click', function () {
            var btn = $(this);
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>保存中...');
            var updates = [];
            $('#permTable tbody tr').each(function () {
                var id = parseInt($(this).data('id'));
                if (!id) return;
                var cells = $(this).find('td');
                updates.push({
                    id: id,
                    profileBasic: $(cells[1]).find('input').prop('checked'),
                    profilePhone: $(cells[2]).find('input').prop('checked'),
                    profileIdCard: $(cells[3]).find('input').prop('checked'),
                    profileCert: $(cells[4]).find('input').prop('checked')
                });
            });
            $.ajax({
                url: '@Url.Action("BatchUpdateTeacherPermissions")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(updates),
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (res) {
                    if (res.success) alert('✅ ' + res.message);
                    else alert('❌ ' + (res.message || '保存失败'));
                    btn.prop('disabled', false).html('<i class="bi bi-check2-all me-1"></i> 保存全部修改');
                },
                error: function () {
                    alert('网络错误，请重试');
                    btn.prop('disabled', false).html('<i class="bi bi-check2-all me-1"></i> 保存全部修改');
                }
            });
        });
    </script>
}
