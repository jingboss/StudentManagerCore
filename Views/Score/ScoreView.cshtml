@using StudentManagerCore.Models
@{
    ViewData["Title"] = "成绩分析";
    var exams = ViewBag.ExamSchedules as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<div class="container-fluid py-3">
    <div class="d-flex align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-bar-chart-line me-2"></i>成绩分析系统</h4>
        <span class="text-danger fw-bold small ms-3">成绩分析、AI 辅助研判功能仅作为教学参考依据，正式数据以教导处统一发布内容为准。</span>
    </div>

    <!-- 筛选条件 -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">选择考试</label>
                    <select id="examSelect" class="form-select" onchange="onExamChange()">
                        <option value="">-- 请选择考试 --</option>
                        @foreach (var exam in exams)
                        {
                            <option value="@exam.Id">@exam.Name（@exam.ExamType · @(((DateTime)exam.ExamDate).ToString("yyyy-MM-dd"))）</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">选择年级</label>
                    <select id="gradeSelect" class="form-select" onchange="onGradeChange()">
                        <option value="">-- 全部年级 --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">选择班级</label>
                    <select id="classSelect" class="form-select" onchange="onClassChange()">
                        <option value="">-- 全部班级 --</option>
                    </select>
                </div>
                <div class="col-md-2" id="compareExamGroup" style="display:none;">
                    <label class="form-label small">对比考试</label>
                    <select id="compareExamSelect" class="form-select" onchange="loadComparisonData()">
                        <option value="">-- 选择对比考试 --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">&nbsp;</label>
                    <button class="btn btn-outline-success form-control btn-sm" onclick="exportExcel()">
                        <i class="bi bi-download me-1"></i>导出 Excel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- 选项卡导航 -->
    <ul class="nav nav-tabs mb-3" id="analysisTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabStats" type="button">
                <i class="bi bi-bar-chart-steps me-1"></i>综合统计
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabDetail" type="button">
                <i class="bi bi-table me-1"></i>学生明细
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabComparison" type="button" onclick="onComparisonTab()">
                <i class="bi bi-arrow-left-right me-1"></i>成绩对比
                <small class="text-muted">（进退分·名次升降）</small>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabTop10" type="button" onclick="onTop10Tab()">
                <i class="bi bi-trophy me-1"></i>年级排名前10名
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabAiAnalysis" type="button" onclick="onAiAnalysisTab()">
                <i class="bi bi-robot me-1"></i>AI成绩分析
            </button>
        </li>
    </ul>

    <div class="tab-content" id="viewContainer" style="display:none;">

        <!-- ============= Tab 1: 综合统计 ============= -->
        <div class="tab-pane fade show active" id="tabStats">
            <!-- 概览卡片 -->
            <div class="row g-2 mb-3" id="overviewCards"></div>

            <!-- 各科统计分析 -->
            <div class="card mb-3">
                <div class="card-header bg-white py-2">
                    <span class="fw-bold"><i class="bi bi-bar-chart-steps me-1"></i>各科统计分析</span>
                    <span class="text-muted small ms-2">平均分 · 最高分 · 最低分 · 中位数 · 优秀率 · 良好率 · 及格率 · 低分率 · 临界生</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover mb-0" style="font-size:0.78rem;">
                            <thead class="table-light" id="statHeader"></thead>
                            <tbody id="statBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- 分数段分布 -->
            <div class="card mb-3">
                <div class="card-header bg-white py-2">
                    <span class="fw-bold"><i class="bi bi-pie-chart me-1"></i>分数段人数分布</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered mb-0" style="font-size:0.8rem;">
                            <thead class="table-light" id="segHeader"></thead>
                            <tbody id="segBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <!-- 分数段分布图表 -->
            <div class="card mb-3">
                <div class="card-header bg-white py-2">
                    <span class="fw-bold"><i class="bi bi-bar-chart me-1"></i>分数段分布柱状图</span>
                    <span class="text-muted small ms-2">直观展示分数集中区间，判断试卷难易</span>
                </div>
                <div class="card-body">
                    <canvas id="chartSegment" style="height:250px; width:100%;"></canvas>
                </div>
            </div>

            <!-- 各科平均分对比图 -->
            <div class="card mb-3">
                <div class="card-header bg-white py-2">
                    <span class="fw-bold"><i class="bi bi-bar-chart-line me-1"></i>各科平均分对比图</span>
                    <span class="text-muted small ms-2">各科平均分与满分对比，了解班级整体学情</span>
                </div>
                <div class="card-body">
                    <canvas id="chartAvgCompare" style="height:250px; width:100%;"></canvas>
                </div>
            </div>
        </div>

        <!-- ============= Tab 2: 学生明细 ============= -->
        <div class="tab-pane fade" id="tabDetail">
            <div class="card">
                <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                    <span class="fw-bold"><i class="bi bi-table me-1"></i>学生成绩明细表</span>
                    <span id="viewStats" class="text-muted small"></span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:600px;overflow-y:auto;">
                        <table class="table table-bordered table-hover mb-0" style="font-size:0.82rem;">
                            <thead class="table-light sticky-top" id="viewHeader"></thead>
                            <tbody id="viewBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- ============= Tab 3: 成绩对比 ============= -->
        <div class="tab-pane fade" id="tabComparison">
            <div class="card">
                <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
                    <span class="fw-bold"><i class="bi bi-arrow-left-right me-1"></i>成绩对比分析</span>
                    <span id="compareStats" class="text-muted small"></span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:650px;overflow-y:auto;">
                        <table class="table table-bordered table-hover mb-0" style="font-size:0.78rem;">
                            <thead class="table-light sticky-top" id="compHeader"></thead>
                            <tbody id="compBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- ============= Tab 4: 年级排名前10名 ============= -->
        <div class="tab-pane fade" id="tabTop10">
            <div class="card border-warning">
                <div class="card-header bg-warning bg-opacity-10 py-2">
                    <span class="fw-bold"><i class="bi bi-trophy me-1"></i>年级排名前10名</span>
                    <span id="top10Stats" class="text-muted small"></span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:600px;overflow-y:auto;">
                        <table class="table table-bordered table-hover mb-0" style="font-size:0.82rem;">
                            <thead class="table-light sticky-top" id="top10Header"></thead>
                            <tbody id="top10Body"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- ============= Tab 5: AI成绩分析 ============= -->
        <div class="tab-pane fade" id="tabAiAnalysis">
            <div class="card">
                <div class="card-header bg-white py-2">
                    <span class="fw-bold"><i class="bi bi-robot me-1"></i>AI智能成绩分析</span>
                    <span class="text-muted small ms-2">基于AI大模型，生成多维度分析报告</span>
                </div>
                <div class="card-body">
                    <!-- 分析类型选择器 -->
                    <div class="row g-3 mb-3">
                        <div class="col-md-2">
                            <label class="form-label small">分析类型</label>
                            <select id="aiAnalysisType" class="form-select" onchange="onAiTypeChange()">
                                <option value="student">学生个人分析</option>
                                <option value="class">班级整体分析</option>
                                <option value="subject">科目分析</option>
                            </select>
                        </div>

                        <!-- 学生分析选择区 -->
                        <div class="col-md-3" id="aiStudentGroup">
                            <label class="form-label small">选择学生</label>
                            <select id="aiStudentSelect" class="form-select">
                                <option value="">-- 请先选择考试 --</option>
                            </select>
                        </div>

                        <!-- 班级分析选择区 -->
                        <div class="col-md-3" id="aiClassGroup" style="display:none;">
                            <label class="form-label small">选择班级</label>
                            <select id="aiClassSelect" class="form-select">
                                <option value="">-- 请先选择考试 --</option>
                            </select>
                        </div>

                        <!-- 科目分析选择区 -->
                        <div class="col-md-4" id="aiSubjectGroup" style="display:none;">
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small">选择班级</label>
                                    <select id="aiSubjectClassSelect" class="form-select" onchange="onAiSubjectClassChange()">
                                        <option value="">-- 请先选择考试 --</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small">选择科目</label>
                                    <select id="aiSubjectSelect" class="form-select">
                                        <option value="">-- 请先选择 --</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- 操作按钮 -->
                        <div class="col-md-3 d-flex align-items-end gap-2">
                            <button class="btn btn-primary" id="btnStartAi" onclick="startAiAnalysis(false)">
                                <i class="bi bi-stars me-1"></i>开始AI分析
                            </button>
                            <button class="btn btn-success" id="btnBatchAi" onclick="startBatchAiAnalysis()" style="display:none;">
                                <i class="bi bi-lightning me-1"></i>批量分析
                            </button>
                            <button class="btn btn-outline-warning" id="btnRegenerateAi" onclick="startAiAnalysis(true)" style="display:none;">
                                <i class="bi bi-arrow-clockwise me-1"></i>重新生成
                            </button>
                            <button class="btn btn-outline-secondary" onclick="clearAiAnalysis()">
                                <i class="bi bi-x-circle me-1"></i>清除
                            </button>
                        </div>
                    </div>
                
                    <!-- 批量进度条 -->
                    <div id="batchProgress" style="display:none;" class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span id="batchProgressText" class="small">正在批量分析...</span>
                            <span id="batchProgressCount" class="small text-muted">0/0</span>
                        </div>
                        <div class="progress" style="height:20px;">
                            <div id="batchProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width:0%;">0%</div>
                        </div>
                        <div id="batchErrors" class="small text-danger mt-1" style="display:none;"></div>
                    </div>
                
                    <!-- 加载中 -->
                    <div id="aiLoading" style="display:none;" class="text-center py-5">
                        <div class="spinner-border text-primary" style="width:3rem;height:3rem;" role="status"></div>
                        <div class="mt-2 text-muted">AI正在分析成绩数据，请稍候（约10~30秒）...</div>
                    </div>
        
                    <!-- 结果展示 -->
                    <div id="aiResultCard" style="display:none;">
                        <div class="alert alert-info py-2" id="aiReportHeader"></div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span id="aiCacheBadge"></span>
                        </div>
                        <div class="card bg-light">
                            <div class="card-body" id="aiAnalysisContent" style="white-space:pre-wrap;line-height:1.8;font-size:0.95rem;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script src="~/js/score-charts.js"></script>
    <script>
        let currentExamId = 0;
        let currentGradeId = 0;
        let currentClassId = 0;
        let cachedData = null;
        let allExams = [];
        let allClasses = [];
        @foreach (var exam in exams)
        {
            <text>allExams.push({ id: @exam.Id, name: '@exam.Name（@exam.ExamType）' });</text>
        }

        function onExamChange() {
            var examId = $('#examSelect').val();
            if (!examId) {
                $('#viewContainer').hide();
                $('#gradeSelect').html('<option value="">-- 全部年级 --</option>');
                $('#classSelect').html('<option value="">-- 全部班级 --</option>');
                return;
            }
            currentExamId = parseInt(examId);
            $('#gradeSelect').html('<option value="">加载中...</option>');
            $('#classSelect').html('<option value="">-- 全部班级 --</option>');

            // 填充对比考试列表（排除自身）
            var compareHtml = '<option value="">-- 选择对比考试 --</option>';
            allExams.forEach(function(e) {
                if (e.id !== currentExamId) {
                    compareHtml += '<option value="' + e.id + '">' + e.name + '</option>';
                }
            });
            $('#compareExamSelect').html(compareHtml);

            $.post('@Url.Action("GetClassList")', { examScheduleId: examId }, function (res) {
                if (!res.success || !res.classes || res.classes.length === 0) {
                    $('#gradeSelect').html('<option value="">-- 暂无数据 --</option>');
                    $('#classSelect').html('<option value="">-- 暂无班级数据 --</option>');
                    // 清空top10缓存
                    $('#top10Header,#top10Body').empty();
                    return;
                }
                allClasses = res.classes;

                // 填充年级下拉
                var gradeHtml = '<option value="">-- 全部年级 --</option>';
                if (res.grades) {
                    res.grades.forEach(function(g) {
                        gradeHtml += '<option value="' + g.gradeLevelId + '">' + g.gradeName + '</option>';
                    });
                }
                $('#gradeSelect').html(gradeHtml);

                // 填充班级下拉
                renderClassList(allClasses);

                // 班主任自动选中其年级和班级
                var teacherGradeLevelId = '@ViewBag.TeacherGradeLevelId';
                var teacherClassInfoId = '@ViewBag.TeacherClassInfoId';
                if (teacherGradeLevelId) {
                    setTimeout(function() {
                        $('#gradeSelect').val(teacherGradeLevelId).trigger('change');
                        if (teacherClassInfoId) {
                            setTimeout(function() {
                                $('#classSelect').val(teacherClassInfoId).trigger('change');
                            }, 300);
                        }
                    }, 100);
                }

                // 隐藏数据，等待用户选年级/班级
                $('#viewContainer').hide();
                // 清空top10缓存
                $('#top10Header,#top10Body').empty();
            }).fail(function() {
                $('#gradeSelect').html('<option value="">-- 加载失败 --</option>');
                $('#classSelect').html('<option value="">-- 加载失败 --</option>');
            });
        }

        function renderClassList(classList) {
            var html = '<option value="">-- 全部班级 --</option>';
            classList.forEach(function (c) {
                html += '<option value="' + c.classInfoId + '">' + c.gradeName + ' ' + c.className + '</option>';
            });
            $('#classSelect').html(html);
        }

        function onGradeChange() {
            var gradeId = parseInt($('#gradeSelect').val() || 0);
            currentGradeId = gradeId;
            // 按年级过滤班级
            if (gradeId && allClasses.length > 0) {
                // 从年级索引反推：每个年级唯一一个名称
                var gradeName = $('#gradeSelect option:selected').text();
                var filtered = allClasses.filter(function(c) { return c.gradeName === gradeName; });
                renderClassList(filtered);
            } else {
                renderClassList(allClasses);
            }
            loadViewData();
        }

        function onClassChange() {
            loadViewData();
            if ($('#compareExamSelect').val()) loadComparisonData();
        }

        function loadViewData() {
            var examId = $('#examSelect').val();
            var gradeId = $('#gradeSelect').val() || '';
            var classId = $('#classSelect').val() || '';
            if (!examId) return;

            currentExamId = parseInt(examId);
            currentGradeId = gradeId ? parseInt(gradeId) : 0;
            currentClassId = classId ? parseInt(classId) : 0;

            $.post('@Url.Action("GetViewData")', {
                examScheduleId: currentExamId,
                gradeLevelId: currentGradeId || null,
                classInfoId: currentClassId || null
            }, function (res) {
                if (!res.success) {
                    alert(res.message);
                    $('#viewContainer').hide();
                    return;
                }
                cachedData = res;
                renderOverview(res);
                renderSubjectStats(res);
                renderSegments(res);
                renderScoreCharts(res.subjectStats);
                renderDetailTable(res);
                $('#viewContainer').show();
            }).fail(function() { alert('加载成绩数据失败'); });
        }

        // ========== 概览卡片 ==========
        function renderOverview(data) {
            var count = data.totalStudentCount || 0;
            var subCount = data.subjects ? data.subjects.length : 0;
            var critical = data.totalCriticalStudents || 0;
            var html = '';
            html += '<div class="col-md-2 col-6"><div class="card bg-primary bg-opacity-10 border-primary"><div class="card-body text-center py-2"><div class="fs-4 fw-bold text-primary">' + count + '</div><small class="text-muted">参考人数</small></div></div></div>';
            html += '<div class="col-md-2 col-6"><div class="card bg-info bg-opacity-10 border-info"><div class="card-body text-center py-2"><div class="fs-4 fw-bold text-info">' + subCount + '</div><small class="text-muted">考试科目</small></div></div></div>';

            if (data.subjectStats && data.subjectStats.length > 0) {
                var totalAvg = 0, totalMax = 0, totalPassRate = 0;
                data.subjectStats.forEach(function(s) {
                    totalAvg += s.avgScore;
                    totalMax = Math.max(totalMax, s.maxScore);
                    totalPassRate += s.passRate;
                });
                totalAvg = (totalAvg / data.subjectStats.length).toFixed(1);
                totalPassRate = (totalPassRate / data.subjectStats.length).toFixed(1);

                html += '<div class="col-md-2 col-6"><div class="card bg-success bg-opacity-10 border-success"><div class="card-body text-center py-2"><div class="fs-4 fw-bold text-success">' + totalAvg + '</div><small class="text-muted">各科平均均分</small></div></div></div>';
                html += '<div class="col-md-2 col-6"><div class="card bg-warning bg-opacity-10 border-warning"><div class="card-body text-center py-2"><div class="fs-4 fw-bold text-warning">' + totalMax.toFixed(1) + '</div><small class="text-muted">单科最高分</small></div></div></div>';
                html += '<div class="col-md-2 col-6"><div class="card" style="background:#fff3cd;border-color:#ffc107;"><div class="card-body text-center py-2"><div class="fs-4 fw-bold" style="color:#856404;">' + totalPassRate + '%</div><small class="text-muted">平均及格率</small></div></div></div>';
                html += '<div class="col-md-2 col-6"><div class="card" style="background:#f8d7da;border-color:#dc3545;"><div class="card-body text-center py-2"><div class="fs-4 fw-bold" style="color:#721c24;">' + critical + '</div><small class="text-muted">临界生人数</small></div></div></div>';
            }
            $('#overviewCards').html(html);
        }

        // ========== 各科统计分析表 ==========
        function renderSubjectStats(data) {
            if (!data.subjectStats || data.subjectStats.length === 0) { $('#statHeader,#statBody').empty(); return; }
            var headerHtml = '<th class="text-center">科目</th>' +
                             '<th class="text-center">满分</th>' +
                             '<th class="text-center">人数</th>' +
                             '<th class="text-center">平均分</th>' +
                             '<th class="text-center">最高分</th>' +
                             '<th class="text-center">最低分</th>' +
                             '<th class="text-center" style="width:48px;font-size:0.8rem;">中位数</th>' +
                             '<th class="text-center">优秀率</th>' +
                             '<th class="text-center">良好率</th>' +
                             '<th class="text-center">及格率</th>' +
                             '<th class="text-center">低分率</th>' +
                             '<th class="text-center">临界生</th>';
            $('#statHeader').html(headerHtml);

            var bodyHtml = '';
            data.subjectStats.forEach(function(s) {
                bodyHtml += '<tr>' +
                    '<td class="fw-bold">' + htmlEncode(s.subjectName) + '</td>' +
                    '<td class="text-center">' + s.fullScore + '</td>' +
                    '<td class="text-center">' + s.studentCount + '</td>' +
                    '<td class="text-center fw-bold text-primary">' + s.avgScore + '</td>' +
                    '<td class="text-center text-success">' + s.maxScore + '</td>' +
                    '<td class="text-center text-danger">' + s.minScore + '</td>' +
                    '<td class="text-center fw-bold">' + s.medianScore + '</td>' +
                    '<td class="text-center"><span class="badge bg-success">' + s.excellentRate + '%</span><br><small class="text-muted">' + s.excellentCount + '人</small></td>' +
                    '<td class="text-center"><span class="badge bg-info">' + s.goodRate + '%</span><br><small class="text-muted">' + s.goodCount + '人</small></td>' +
                    '<td class="text-center"><span class="badge bg-primary">' + s.passRate + '%</span><br><small class="text-muted">' + s.passCount + '人</small></td>' +
                    '<td class="text-center"><span class="badge ' + (s.lowRate > 10 ? 'bg-danger' : 'bg-secondary') + '">' + s.lowRate + '%</span><br><small class="text-muted">' + s.lowCount + '人</small></td>' +
                    '<td class="text-center"><span class="badge bg-warning text-dark">' + s.criticalCount + '人</span></td>' +
                    '</tr>';
            });
            $('#statBody').html(bodyHtml);
        }

