        function htmlEncode(str) {
            return $('<span>').text(str || '').html();
        }

        // ========== Tab 5: AI成绩分析 ==========

        function renderAnalysisHtml(text) {
            var html = (text || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                .replace(/\n/g, '<br>')
                .replace(/### (.*?)(?:<br>|$)/g, '<h6 class="mt-3 mb-2 text-primary">$1</h6>')
                .replace(/## (.*?)(?:<br>|$)/g, '<h5 class="mt-3 mb-2 fw-bold">$1</h5>')
                .replace(/- (.*?)(?:<br>|$)/g, '<li>$1</li>');
            html = html.replace(/(<li>.*?<\/li>)/g, '<ul class="mb-2">$1</ul>');
            html = html.replace(/<\/ul>\s*<ul class="mb-2">/g, '');
            return html;
        }

