        function renderSegments(data) {
            if (!data.subjectStats || data.subjectStats.length === 0) { $('#segHeader,#segBody').empty(); return; }
            var headerHtml = '<th class="text-center">科目</th>' +
                             '<th class="text-center bg-danger bg-opacity-10" style="min-width:80px;">&lt;60%<br><small class="text-muted">不及格</small></th>' +
                             '<th class="text-center bg-warning bg-opacity-10" style="min-width:80px;">60%~69%<br><small class="text-muted">及格</small></th>' +
                             '<th class="text-center bg-info bg-opacity-10" style="min-width:80px;">70%~79%<br><small class="text-muted">中等</small></th>' +
                             '<th class="text-center" style="min-width:90px;background:#d4edda;">80%~89%<br><small class="text-muted">良好</small></th>' +
                             '<th class="text-center bg-primary bg-opacity-10" style="min-width:80px;">90%~100%<br><small class="text-muted">优秀</small></th>';
            $('#segHeader').html(headerHtml);

            var bodyHtml = '';
            data.subjectStats.forEach(function(s) {
                var total = s.seg0_59 + s.seg60_69 + s.seg70_79 + s.seg80_89 + s.seg90_100;
                function bar(cnt, clr) {
                    if (total === 0) return '<div style="height:20px;background:#eee;border-radius:3px;"></div>';
                    var pct = (cnt / total * 100).toFixed(1);
                    return '<div style="height:20px;background:' + clr + ';width:' + pct + '%;min-width:4px;border-radius:3px;" title="' + cnt + '人(' + pct + '%)"></div>';
                }
                bodyHtml += '<tr>' +
                    '<td class="fw-bold align-middle">' + htmlEncode(s.subjectName) + '</td>' +
                    '<td class="text-center align-middle">' + s.seg0_59 + '<br><small class="text-muted">(' + (total > 0 ? (s.seg0_59/total*100).toFixed(1) : 0) + '%)</small></td>' +
                    '<td class="text-center align-middle">' + s.seg60_69 + '<br><small class="text-muted">(' + (total > 0 ? (s.seg60_69/total*100).toFixed(1) : 0) + '%)</small></td>' +
                    '<td class="text-center align-middle">' + s.seg70_79 + '<br><small class="text-muted">(' + (total > 0 ? (s.seg70_79/total*100).toFixed(1) : 0) + '%)</small></td>' +
                    '<td class="text-center align-middle">' + s.seg80_89 + '<br><small class="text-muted">(' + (total > 0 ? (s.seg80_89/total*100).toFixed(1) : 0) + '%)</small></td>' +
                    '<td class="text-center align-middle">' + s.seg90_100 + '<br><small class="text-muted">(' + (total > 0 ? (s.seg90_100/total*100).toFixed(1) : 0) + '%)</small></td>' +
                    '</tr>' +
                    // 可视化进度条
                    '<tr style="background:#f8f9fa;">' +
                    '<td></td>' +
                    '<td colspan="5" class="p-1">' +
                    '<div class="d-flex" style="gap:2px;height:20px;">' +
                    bar(s.seg0_59, '#dc3545') +
                    bar(s.seg60_69, '#ffc107') +
                    bar(s.seg70_79, '#17a2b8') +
                    bar(s.seg80_89, '#28a745') +
                    bar(s.seg90_100, '#007bff') +
                    '</div></td></tr>';
            });
            $('#segBody').html(bodyHtml);
        }

