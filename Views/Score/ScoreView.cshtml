        }

        function onAiSubjectClassChange() {
            var examId = $('#examSelect').val();
            if (!examId) return;
            $('#aiSubjectSelect').html('<option value="">加载中...</option>');
            $.post('@Url.Action("GetAiSubjectList")', { examScheduleId: parseInt(examId) }, function (res) {
                if (!res.success || !res.subjects) { $('#aiSubjectSelect').html('<option value="">-- 加载失败 --</option>'); return; }
                var html = '<option value="">-- 请选择科目 --</option>';
                res.subjects.forEach(function (s) { html += '<option value="' + s.subjectId + '">' + htmlEncode(s.subjectName) + '</option>'; });
                $('#aiSubjectSelect').html(html);
            }).fail(function () { $('#aiSubjectSelect').html('<option value="">-- 加载失败 --</option>'); });
        }

        function startSubjectAnalysis(forceRegenerate) {
            var examId = $('#examSelect').val();
            var classId = $('#aiSubjectClassSelect').val();
            var subjectId = $('#aiSubjectSelect').val();
            if (!examId) { alert('请先选择考试'); return; }
            if (!classId) { alert('请先选择班级'); return; }
            if (!subjectId) { alert('请先选择科目'); return; }
            var token = $('input[name="__RequestVerificationToken"]').val();
            $('#aiLoading').show();
            $('#aiResultCard').hide();
            $('#aiAnalysisContent').empty();
            $('#btnRegenerateAi').hide();
            $('html, body').animate({ scrollTop: $('#aiLoading').offset().top - 100 }, 500);
            $.ajax({
                url: '@Url.Action("GetAiSubjectAnalysis")',
                type: 'POST',
                data: { examScheduleId: parseInt(examId), classInfoId: parseInt(classId), subjectId: parseInt(subjectId), forceRegenerate: forceRegenerate || false },
                headers: token ? { 'RequestVerificationToken': token } : {}
            }).done(function (res) {
                $('#aiLoading').hide();
                if (!res.success) {
                    $('#aiAnalysisContent').html('<div class="alert alert-danger mb-0">' + htmlEncode(res.message || '科目分析失败') + '</div>');
                    $('#aiResultCard').show();
                    return;
                }
                $('#aiReportHeader').text('' + htmlEncode(res.typeName || '科目分析报告'));
                if (res.cached) {
                    $('#aiCacheBadge').html('<span class="badge bg-success bg-opacity-75"><i class="bi bi-database me-1"></i>缓存报告（' + htmlEncode(res.updatedAt || '') + '生成）</span>' +
                        '<button class="btn btn-sm btn-outline-warning ms-2" onclick="startSubjectAnalysis(true)"><i class="bi bi-arrow-clockwise"></i> 重新生成</button>');
                } else {
                    $('#aiCacheBadge').html('<span class="badge bg-info"><i class="bi bi-stars me-1"></i>新生成的报告</span>');
                }
                $('#btnRegenerateAi').show();
                $('#aiAnalysisContent').html(renderAnalysisHtml(res.analysis));
                $('#aiResultCard').show();
                $('html, body').animate({ scrollTop: $('#aiResultCard').offset().top - 100 }, 500);
            }).fail(function () {
                $('#aiLoading').hide();
                $('#aiAnalysisContent').html('<div class="alert alert-danger mb-0">网络错误，科目分析请求失败</div>');
                $('#aiResultCard').show();
            });
        }

        function startAiAnalysis(forceRegenerate) {
            var type = $('#aiAnalysisType').val();
            if (type === 'student') startStudentAnalysis(forceRegenerate);
            else if (type === 'class') startClassAnalysis(forceRegenerate);
            else if (type === 'subject') startSubjectAnalysis(forceRegenerate);
        }

        function startBatchAiAnalysis() {
            var examId = $('#examSelect').val();
            var gradeId = $('#gradeSelect').val() || '';
            var classId = $('#classSelect').val() || '';
            if (!examId) { alert('请先选择考试'); return; }
            if (!gradeId && !classId) { alert('请先选择年级或班级，缩小批量分析范围'); return; }
            if (!confirm('将对该年级/班级的所有学生进行AI分析（已缓存的跳过），确定继续？')) return;
            var token = $('input[name="__RequestVerificationToken"]').val();
            $('#btnBatchAi').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>分析中...');
            $('#batchProgress').show();
            $('#batchErrors').hide();
            $('#aiResultCard').hide();
            doBatchRequest(examId, gradeId, classId, token);
        }

        function doBatchRequest(examId, gradeId, classId, token) {
            $.ajax({
                url: '@Url.Action("BatchAiAnalysis")',
                type: 'POST',
                data: { examScheduleId: parseInt(examId), gradeLevelId: gradeId ? parseInt(gradeId) : null, classInfoId: classId ? parseInt(classId) : null },
                headers: token ? { 'RequestVerificationToken': token } : {}
            }).done(function (res) {
                if (!res.success) {
                    $('#batchProgressText').text('批量分析失败');
                    $('#btnBatchAi').prop('disabled', false).html('<i class="bi bi-lightning me-1"></i>批量分析');
                    alert(res.message || '批量分析失败');
                    return;
                }
                var done = res.cachedCount + res.processed;
                var pct = res.total > 0 ? Math.round(done / res.total * 100) : 0;
                $('#batchProgressText').text('已分析 ' + done + ' / ' + res.total + ' 名学生');
                $('#batchProgressCount').text(done + '/' + res.total);
                $('#batchProgressBar').css('width', pct + '%').text(pct + '%');
                if (res.errors) { $('#batchErrors').show().text('部分失败: ' + res.errors); }
                if (res.done) {
                    $('#batchProgressText').text('批量分析完成！共 ' + res.total + ' 名学生，新增 ' + res.processed + ' 份报告');
                    $('#batchProgressBar').removeClass('progress-bar-animated').addClass('bg-success');
                    $('#btnBatchAi').prop('disabled', false).html('<i class="bi bi-lightning me-1"></i>批量分析');
                    loadAiStudentList();
                } else {
                    setTimeout(function () { doBatchRequest(examId, gradeId, classId, token); }, 1500);
                }
            }).fail(function () {
                $('#batchProgressText').text('网络错误，批量分析中断');
                $('#btnBatchAi').prop('disabled', false).html('<i class="bi bi-lightning me-1"></i>批量分析');
            });
        }

        function clearAiAnalysis() {
            $('#aiResultCard').hide();
            $('#aiAnalysisContent').empty();
            $('#aiCacheBadge').empty();
            $('#btnRegenerateAi').hide();
            $('#aiReportHeader').text('');
            $('#aiStudentSelect').val('');
        }
    </script>
}
