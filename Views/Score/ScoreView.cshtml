        function renderComparison(data) {
            $('#compareStats').text(data.rows.length + ' 名学生 · ' + data.examName + ' vs ' + data.compareExamName);

            var headerHtml = '<th class="text-center" style="width:30px;">排名</th>' +
                             '<th style="width:48px;">学号</th>' +
                             '<th style="width:45px;">姓名</th>' +
                             '<th class="text-center" style="width:45px;">当前总分</th>' +
                             '<th class="text-center" style="width:40px;">原总分</th>' +
                             '<th class="text-center" style="width:45px;">进退分</th>' +
                             '<th class="text-center" style="width:35px;">当前<br>排名</th>' +
                             '<th class="text-center" style="width:35px;">原<br>排名</th>' +
                             '<th class="text-center" style="width:40px;">名次<br>升降</th>';
            data.subjects.forEach(function (sub) {
                headerHtml += '<th class="text-center" style="min-width:75px;">' + sub.subjectName + '<br><small class="text-muted">当前/原/进退</small></th>';
            });
            $('#compHeader').html(headerHtml);

            var bodyHtml = '';
            data.rows.forEach(function (row) {
                var rankClass = '';
                if (row.rank1 === 1) rankClass = 'table-warning';
                else if (row.rank1 <= 3) rankClass = 'table-info';

                var totalDiffCls = row.totalDiff > 0 ? 'text-success' : (row.totalDiff < 0 ? 'text-danger' : '');
                var totalDiffStr = row.totalDiff > 0 ? '+' + row.totalDiff : (row.totalDiff === 0 ? '0' : row.totalDiff);

                var rankChangeStr = '', rankChangeCls = '';
                if (row.rankChange !== null && row.rankChange !== undefined) {
                    if (row.rankChange < 0) {
                        rankChangeStr = '↑' + Math.abs(row.rankChange);
                        rankChangeCls = 'text-success';
                    } else if (row.rankChange > 0) {
                        rankChangeStr = '↓' + row.rankChange;
                        rankChangeCls = 'text-danger';
                    } else {
                        rankChangeStr = '—';
                        rankChangeCls = 'text-muted';
                    }
                }

                bodyHtml += '<tr class="' + rankClass + '">' +
                    '<td class="text-center fw-bold">' + row.rank1 + '</td>' +
                    '<td>' + htmlEncode(row.studentNo) + '</td>' +
                    '<td>' + htmlEncode(row.studentName) + '</td>' +
                    '<td class="text-center fw-bold">' + row.totalScore + '</td>' +
                    '<td class="text-center">' + (row.hasComparison ? row.oldTotal : '-') + '</td>' +
                    '<td class="text-center fw-bold ' + totalDiffCls + '">' + (row.hasComparison ? totalDiffStr : '-') + '</td>' +
                    '<td class="text-center">' + row.rank1 + '</td>' +
                    '<td class="text-center">' + (row.rank2 != null ? row.rank2 : '-') + '</td>' +
                    '<td class="text-center fw-bold ' + rankChangeCls + '">' + (row.hasComparison ? rankChangeStr : '-') + '</td>';

                data.subjects.forEach(function (sub) {
                    var sd = row.scoreDiffs ? row.scoreDiffs.find(function(d) { return d.subjectId === sub.subjectId; }) : null;
                    if (sd) {
                        var diffCls = sd.diff > 0 ? 'text-success' : (sd.diff < 0 ? 'text-danger' : '');
                        var diffStr = sd.diff > 0 ? '+' + sd.diff : sd.diff;
                        bodyHtml += '<td class="text-center small">' + sd.newScore + ' / ' + sd.oldScore +
                            '<br><span class="' + diffCls + ' fw-bold">' + diffStr + '</span></td>';
                    } else {
                        bodyHtml += '<td class="text-center text-muted">-</td>';
                    }
                });

                bodyHtml += '</tr>';
            });
            $('#compBody').html(bodyHtml);
        }

