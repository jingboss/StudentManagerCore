        function startStudentAnalysis(forceRegenerate) {
            var examId = $('#examSelect').val();
            var studentId = $('#aiStudentSelect').val();
            if (!examId) { alert('请先选择考试'); return; }
            if (!studentId) { alert('请先选择学生'); return; }
            var token = $('input[name="__RequestVerificationToken"]').val();
            $('#aiLoading').show();
            $('#aiResultCard').hide();
            $('#aiAnalysisContent').empty();
            $('#btnRegenerateAi').hide();
            $('html, body').animate({ scrollTop: $('#aiLoading').offset().top - 100 }, 500);
            $.ajax({
                url: '@Url.Action("GetAiAnalysis")',
                type: 'POST',
                data: {
                    examScheduleId: parseInt(examId),
                    studentId: parseInt(studentId),
                    forceRegenerate: forceRegenerate || false
                },
                headers: token ? { 'RequestVerificationToken': token } : {}
            }).done(function (res) {
                $('#aiLoading').hide();
                if (!res.success) {
                    $('#aiAnalysisContent').html('<div class="alert alert-danger mb-0">' + htmlEncode(res.message || 'AI分析失败') + '</div>');
                    $('#aiResultCard').show();
                    return;
                }
                $('#aiReportHeader').text('学生：' + htmlEncode(res.studentName) + ' 的成绩分析报告');
                if (res.cached) {
                    $('#aiCacheBadge').html('<span class="badge bg-success bg-opacity-75"><i class="bi bi-database me-1"></i>缓存报告（' + htmlEncode(res.updatedAt || '') + '生成）</span>' +
                        '<button class="btn btn-sm btn-outline-warning ms-2" onclick="startStudentAnalysis(true)"><i class="bi bi-arrow-clockwise"></i> 重新生成</button>');
                } else {
                    $('#aiCacheBadge').html('<span class="badge bg-info"><i class="bi bi-stars me-1"></i>新生成的报告</span>');
                }
                $('#btnRegenerateAi').show();
                $('#aiAnalysisContent').html(renderAnalysisHtml(res.analysis));
                $('#aiResultCard').show();
                $('html, body').animate({ scrollTop: $('#aiResultCard').offset().top - 100 }, 500);
            }).fail(function () {
                $('#aiLoading').hide();
                $('#aiAnalysisContent').html('<div class="alert alert-danger mb-0">网络错误，AI分析请求失败</div>');
                $('#aiResultCard').show();
            });
        }

