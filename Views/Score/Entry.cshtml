@using StudentManagerCore.Models
@{
    ViewData["Title"] = "成绩录入";
    var exams = ViewBag.ExamSchedules as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}
<style>
    /* 去掉 number 输入框的上下箭头 */
    .score-input::-webkit-inner-spin-button,
    .score-input::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    .score-input[type="number"] {
        -moz-appearance: textfield;
        appearance: textfield;
    }
</style>
<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>成绩录入</h4>
    </div>

    @Html.AntiForgeryToken()

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">选择考试</label>
                    <select id="examSelect" class="form-select" onchange="onExamChange()">
                        <option value="">-- 请选择考试 --</option>
                        @foreach (var exam in exams)
                        {
                            <option value="@exam.Id" data-status="@exam.Status">
                                @exam.Name（@exam.ExamType · @(((DateTime)exam.ExamDate).ToString("yyyy-MM-dd"))）
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">考试状态</label>
                    <input id="examStatus" class="form-control" readonly value="请先选择考试" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">年级筛选</label>
                    <select id="gradeFilter" class="form-select" onchange="onFilterChange()" disabled>
                        <option value="">全部年级</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">班级筛选</label>
                    <select id="classFilter" class="form-select" onchange="onFilterChange()" disabled>
                        <option value="">全部班级</option>
                    </select>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button id="clearFilterBtn" class="btn btn-outline-secondary btn-sm" onclick="clearFilters()" disabled>
                        <i class="bi bi-x-circle"></i> 清除
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="entryContainer" style="display:none;">
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center py-2">
                <span id="entryTitle" class="fw-bold"><i class="bi bi-table me-1"></i>录入表</span>
                <div>
                    <span id="saveStatus" class="text-muted me-2 small"></span>
                    <span class="badge bg-info me-2" style="font-size:0.7rem;">⚡ 失焦自动保存</span>
                    <button id="saveAllBtn" class="btn btn-primary btn-sm" onclick="saveAllScores()">
                        <i class="bi bi-save me-1"></i>保存全部
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive" style="max-height:70vh;">
                    <table class="table table-bordered table-hover mb-0" style="font-size:0.85rem;">
                        <thead class="table-light" id="entryHeader"></thead>
                        <tbody id="entryBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentExamScheduleId = 0;
        let scoreCache = {};     // key: studentId_subjectId → {val: number|null, absent: bool}
        let scoreChanged = {};   // key: studentId_subjectId → {val: number, absent: bool}

        // ========== 考试切换 ==========
        function onExamChange() {
            // 重置筛选
            $('#gradeFilter').empty().append('<option value="">全部年级</option>').prop('disabled', true);
            $('#classFilter').empty().append('<option value="">全部班级</option>').prop('disabled', true);
            $('#clearFilterBtn').prop('disabled', true);
            loadEntryData();
        }

        // ========== 筛选变更 ==========
        function onFilterChange() {
            var changed = Object.keys(scoreChanged).length;
            if (changed > 0 && !confirm('有 ' + changed + ' 项成绩未保存，切换筛选将丢弃更改。确定吗？')) return;
            loadEntryData();
        }

        // ========== 清除筛选 ==========
        function clearFilters() {
            var changed = Object.keys(scoreChanged).length;
            if (changed > 0 && !confirm('有 ' + changed + ' 项成绩未保存，清除筛选将丢弃更改。确定吗？')) return;
            $('#gradeFilter').val('');
            $('#classFilter').empty().append('<option value="">全部班级</option>');
            $('#classFilter').prop('disabled', true);
            $('#clearFilterBtn').prop('disabled', true);
            loadEntryData();
        }

        // ========== 加载考试数据 ==========
        function loadEntryData() {
            var examId = parseInt($('#examSelect').val() || 0);
            currentExamScheduleId = examId;

            if (!examId) {
                $('#entryContainer').hide();
                $('#examStatus').val('请先选择考试');
                return;
            }

            var status = $('#examSelect option:selected').data('status');
            $('#examStatus').val(status || '未知');

            // 仅进行中可编辑
            var isActive = (status === '进行中');

            var grade = $('#gradeFilter').val() || '';
            var className = $('#classFilter').val() || '';

            $.ajax({
                url: '@Url.Action("GetEntryData")',
                type: 'POST',
                data: { examScheduleId: examId, grade: grade, className: className },
                success: function (res) {
                    if (!res.success) {
                        $('#entryContainer').hide();
                        alert(res.message);
                        return;
                    }
                    scoreCache = {};
                    scoreChanged = {};
                    renderEntryTable(res, isActive);
                    // 填充筛选下拉框
                    populateFilters(res, grade, className);
                    $('#entryContainer').show();
                    $('#saveStatus').text('✅ 已加载');
                },
                error: function (xhr) {
                    $('#entryContainer').hide();
                    var msg = '加载数据失败';
                    if (xhr.status === 404) msg = '请求地址不存在（404）';
                    else if (xhr.status === 500) msg = '服务器内部错误（500）';
                    else if (xhr.status === 405) msg = '请求方法不被允许（405）';
                    else if (xhr.status === 0) msg = '无法连接服务器，请检查网络';
                    alert(msg);
                }
            });
        }

        // ========== 填充筛选下拉框 ==========
        function populateFilters(data, selectedGrade, selectedClass) {
            var grades = data.availableGrades || [];
            var classes = data.availableClasses || [];

            // 年级下拉
            var gradeSelect = $('#gradeFilter');
            gradeSelect.empty().append('<option value="">全部年级</option>');
            grades.forEach(function (g) {
                gradeSelect.append('<option value="' + htmlEncode(g) + '">' + htmlEncode(g) + '</option>');
            });

            // 班级下拉
            var classSelect = $('#classFilter');
            classSelect.empty().append('<option value="">全部班级</option>');
            classes.forEach(function (c) {
                classSelect.append('<option value="' + htmlEncode(c) + '">' + htmlEncode(c) + '</option>');
            });

            // 恢复选中值
            if (selectedGrade) { gradeSelect.val(selectedGrade); gradeSelect.prop('disabled', false); }
            else { gradeSelect.prop('disabled', grades.length === 0); }

            if (selectedClass) { classSelect.val(selectedClass); classSelect.prop('disabled', false); }
            else { classSelect.prop('disabled', classes.length === 0); }

            $('#clearFilterBtn').prop('disabled', !selectedGrade && !selectedClass);
        }

        // ========== 渲染录入表 ==========
        function renderEntryTable(data, isActive) {
            var subjects = data.subjects || [];
            var students = data.students || [];
            var existingScores = data.existingScores || [];

            // 构建索引
            existingScores.forEach(function (sc) {
                var key = sc.studentId + '_' + sc.subjectId;
                scoreCache[key] = { val: sc.scoreValue, absent: sc.isAbsent };
            });

            // 表头
            var examName = $('#examSelect option:selected').text();
            $('#entryTitle').text('录入表 · ' + examName);

            var headerHtml = '<th style="min-width:40px;">序号</th><th style="min-width:80px;">学号</th><th style="min-width:60px;">姓名</th><th style="min-width:80px;">年级</th><th style="min-width:80px;">班级</th>';
            subjects.forEach(function (sub) {
                headerHtml += '<th class="text-center">' + sub.subjectName + '<br><small class="text-muted">满分' + sub.fullScore + '</small></th>';
            });
            $('#entryHeader').html(headerHtml);

            // 表体
            var bodyHtml = '';
            students.forEach(function (stu, idx) {
                bodyHtml += '<tr>';
                bodyHtml += '<td class="text-center">' + (idx + 1) + '</td>';
                bodyHtml += '<td>' + htmlEncode(stu.studentNo) + '</td>';
                bodyHtml += '<td>' + htmlEncode(stu.name) + '</td>';
                bodyHtml += '<td>' + htmlEncode(stu.grade) + '</td>';
                bodyHtml += '<td>' + htmlEncode(stu.className) + '</td>';

                subjects.forEach(function (sub) {
                    var key = stu.studentID + '_' + sub.subjectId;
                    var cache = scoreCache[key];
                    var isAbsent = cache ? cache.absent : false;
                    var val = cache ? cache.val : null;
                    var displayVal = (val !== undefined && val !== null) ? val : '';

                    bodyHtml += '<td class="text-center p-1" style="white-space:nowrap;">';
                    bodyHtml += '<input type="number" class="form-control form-control-sm score-input text-center d-inline-block" ' +
                        'style="width:75px;" ' +
                        'data-student="' + stu.studentID + '" ' +
                        'data-subject="' + sub.subjectId + '" ' +
                        'data-fullscore="' + sub.fullScore + '" ' +
                        'value="' + displayVal + '" ' +
                        'oninput="onScoreChange(this)" ' +
                        'onblur="onScoreBlur(this)" ' +
                        'onkeydown="onScoreKeydown(event, this)" ' +
                        'step="0.5" min="0" max="' + sub.fullScore + '" ' +
                        (isAbsent ? 'disabled' : '') + ' />';
                    bodyHtml += '<label class="ms-1 small text-nowrap" style="cursor:pointer;font-size:0.75rem;">' +
                        '<input type="checkbox" class="absent-check" ' +
                        'data-student="' + stu.studentID + '" ' +
                        'data-subject="' + sub.subjectId + '" ' +
                        'onchange="onAbsentChange(this)" ' +
                        (isAbsent ? 'checked' : '') + ' /> 缺考</label>';
                    bodyHtml += '</td>';
                });

                bodyHtml += '</tr>';
            });
            $('#entryBody').html(bodyHtml);

            // 禁用输入控件（非进行中状态）
            if (!isActive) {
                $('.score-input').prop('readonly', true);
                $('.absent-check').prop('disabled', true);
            }

            // 禁止鼠标滚轮改变分数值
            $('#entryBody').on('wheel', '.score-input', function (e) {
                e.preventDefault();
            });
        }

        // ========== 分数输入变化跟踪 ==========
        function onScoreChange(input) {
            var studentId = $(input).data('student');
            var subjectId = $(input).data('subject');
            var fullScore = parseInt($(input).data('fullscore')) || 100;
            var key = studentId + '_' + subjectId;
            var val = $(input).val();

            // 超满分视觉提示
            var numVal = parseFloat(val);
            if (val !== '' && !isNaN(numVal) && (numVal < 0 || numVal > fullScore)) {
                $(input).addClass('is-invalid');
            } else {
                $(input).removeClass('is-invalid');
            }

            var isAbsent = $('.absent-check[data-student="' + studentId + '"][data-subject="' + subjectId + '"]').is(':checked');
            if (val === '' && !isAbsent) {
                delete scoreChanged[key];
            } else {
                scoreChanged[key] = { val: numVal || 0, absent: isAbsent };
            }

            var changed = Object.keys(scoreChanged).length;
            $('#saveStatus').text(changed > 0 ? '⚠️ ' + changed + ' 项待保存' : '✅ 全部已保存');
        }

        // ========== 缺考勾选 ==========
        function onAbsentChange(chk) {
            var studentId = $(chk).data('student');
            var subjectId = $(chk).data('subject');
            var key = studentId + '_' + subjectId;
            var input = $('.score-input[data-student="' + studentId + '"][data-subject="' + subjectId + '"]');
            var isChecked = $(chk).is(':checked');

            if (isChecked) {
                input.val('').prop('disabled', true).removeClass('is-invalid');
            } else {
                input.prop('disabled', false).focus();
            }

            // 更新缓存
            if (scoreCache[key]) {
                scoreCache[key].absent = isChecked;
            } else {
                scoreCache[key] = { val: null, absent: isChecked };
            }

            scoreChanged[key] = isChecked ? { val: 0, absent: true } : { val: parseFloat(input.val()) || 0, absent: false };

            var changed = Object.keys(scoreChanged).length;
            $('#saveStatus').text(changed > 0 ? '⚠️ ' + changed + ' 项待保存' : '✅ 全部已保存');
        }

        // ========== 键盘导航：Enter 向下 · Tab 向右 ==========
        function onScoreKeydown(event, input) {
            if (event.key === 'Enter') {
                event.preventDefault();
                // 计算当前列索引
                var $td = $(input).closest('td');
                var $tr = $(input).closest('tr');
                var colIdx = $tr.children('td').index($td);
                // 找下一行同一列
                var $nextTr = $tr.next('tr');
                if ($nextTr.length) {
                    var $nextTd = $nextTr.children('td').eq(colIdx);
                    var $nextInput = $nextTd.find('.score-input:enabled');
                    if ($nextInput.length) {
                        $nextInput.focus();
                        $nextInput.select();
                    } else {
                        // 缺考禁用则跳到同行下一个可用输入
                        var $nextInputs = $nextTr.find('.score-input:enabled');
                        var nextColIdx = Math.min(colIdx, $nextInputs.length - 1);
                        if ($nextInputs.eq(nextColIdx).length) {
                            $nextInputs.eq(nextColIdx).focus().select();
                        }
                    }
                }
            } else if (event.key === 'Tab') {
                event.preventDefault();
                var inputs = $('.score-input:enabled');
                var idx = inputs.index(input);
                var next = inputs.eq(idx + 1);
                if (next.length) {
                    next.focus();
                    next.select();
                }
            }
        }

        // ========== 失焦自动保存 ==========
        function onScoreBlur(input) {
            var studentId = $(input).data('student');
            var subjectId = $(input).data('subject');
            var key = studentId + '_' + subjectId;
            var val = $(input).val().trim();
            var isAbsent = $('.absent-check[data-student="' + studentId + '"][data-subject="' + subjectId + '"]').is(':checked');
            var cached = scoreCache[key];
            var newVal = val === '' ? null : parseFloat(val);

            // 如果缺考状态没变且分数没变，跳过
            if (cached && cached.absent === isAbsent && (cached.val === newVal || (cached.val === null && (val === '' || val === null)))) return;
            if (!cached && val === '' && !isAbsent) return;

            // 分数和缺考都为空，跳过
            if ((val === '' || isNaN(newVal)) && !isAbsent) return;

            // 超满分检查
            var fullScore = parseInt($(input).data('fullscore')) || 100;
            if (!isAbsent && newVal !== null && (newVal < 0 || newVal > fullScore)) {
                $('#saveStatus').text('⚠️ 分数 ' + newVal + ' 超出满分 ' + fullScore + '，未保存');
                return;
            }

            var item = [{
                studentId: parseInt(studentId),
                subjectId: parseInt(subjectId),
                scoreValue: isAbsent ? 0 : (newVal || 0),
                isAbsent: isAbsent
            }];

            $(input).prop('readonly', true);
            $('#saveStatus').text('⏳ 自动保存中...');

            $.ajax({
                url: '@Url.Action("SaveScores")?examScheduleId=' + currentExamScheduleId,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(item),
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (res) {
                    if (res.success) {
                        scoreCache[key] = { val: isAbsent ? 0 : (newVal || 0), absent: isAbsent };
                        delete scoreChanged[key];
                        var changed = Object.keys(scoreChanged).length;
                        $('#saveStatus').text(changed > 0 ? '⚠️ ' + changed + ' 项待保存 | ✅ 已自动保存' : '✅ 已自动保存，全部已保存');
                    } else {
                        $('#saveStatus').text('❌ 自动保存失败: ' + (res.message || '未知错误'));
                    }
                },
                error: function (xhr) {
                    $('#saveStatus').text('❌ 自动保存失败: ' + (xhr.responseText || '网络错误'));
                },
                complete: function () {
                    $(input).prop('readonly', false);
                }
            });
        }

        // ========== 保存全部 ==========
        function saveAllScores() {
            // 检查是否有超出满分的输入
            var invalidInputs = $('.score-input.is-invalid');
            if (invalidInputs.length > 0) {
                if (!confirm('有 ' + invalidInputs.length + ' 个分数超出满分，确定要保存吗？')) {
                    return;
                }
            }

            var changed = Object.keys(scoreChanged);
            if (changed.length === 0) {
                alert('没有需要保存的数据');
                return;
            }

            var items = [];
            changed.forEach(function (key) {
                var parts = key.split('_');
                var changedVal = scoreChanged[key];
                var scoreVal = (typeof changedVal === 'object') ? (changedVal.val || 0) : (changedVal || 0);
                var absent = (typeof changedVal === 'object') ? changedVal.absent : false;
                items.push({
                    studentId: parseInt(parts[0]),
                    subjectId: parseInt(parts[1]),
                    scoreValue: scoreVal,
                    isAbsent: absent
                });
            });

            $('#saveAllBtn').prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>保存中...');

            $.ajax({
                url: '@Url.Action("SaveScores")?examScheduleId=' + currentExamScheduleId,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(items),
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (res) {
                    if (res.success) {
                        $('#saveStatus').text('✅ 保存成功: ' + res.message);
                        scoreChanged = {};
                        loadEntryData();
                    } else {
                        alert(res.message);
                    }
                },
                error: function (xhr) {
                    alert('保存失败: ' + (xhr.responseText || '请重试'));
                },
                complete: function () {
                    $('#saveAllBtn').prop('disabled', false).html('<i class="bi bi-save me-1"></i>保存全部');
                }
            });
        }

        function htmlEncode(str) {
            return $('<span>').text(str || '').html();
        }
    </script>
}
