@section Scripts {
    <script>
        $(function () {
            var token = $('input[name="__RequestVerificationToken"]').val();

            // ---- 新增考试
            $('#addSubmit').click(function () {
                var btn = $(this);
                btn.prop('disabled', true);
                var checkedGrades = $('input[name="gradeItem"]:checked').map(function () { return $(this).val(); }).get().join(',');
                $.post('@Url.Action("Create")', {
                    name: $('#addModal input[name="name"]').val(),
                    examType: $('#addModal select[name="examType"]').val(),
                    grades: checkedGrades || '',
                    examDate: $('#addModal input[name="examDate"]').val(),
                    endDate: $('#addModal input[name="endDate"]').val() || '',
                    semesterId: $('#addModal select[name="semesterId"]').val(),
                    status: $('#addModal select[name="status"]').val(),
                    __RequestVerificationToken: token
                }, function (res) {
                    btn.prop('disabled', false);
                    if (res.success) { location.reload(); }
                    else { alert(res.message || '保存失败'); }
                }).fail(function (xhr) {
                    btn.prop('disabled', false);
