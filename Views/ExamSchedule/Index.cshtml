            // ---- 考试时间设置 ----
            $(document).on('click', '.exam-time-btn', function () {
                var examId = $(this).data('id');
                var examName = $(this).data('name');
                $('#examTimeTitle').text(examName);
                $('#examTimeScheduleId').val(examId);
                $('#examTimeBody').html('<tr><td colspan="3" class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-1"></span>加载中...</td></tr>');
                $('#examTimeModal').modal('show');

                $.get('@Url.Action("GetExamSubjectTimes")', { examScheduleId: examId }, function (res) {
                    if (!res.success) {
                        $('#examTimeBody').html('<tr><td colspan="4" class="text-danger text-center py-4">' + htmlEncode(res.message) + '</td></tr>');
                        return;
                    }
                    if (!res.data || res.data.length === 0) {
                        $('#examTimeBody').html('<tr><td colspan="4" class="text-muted text-center py-4">暂无可设置时间的科目，请先在"科目"中安排考试科目</td></tr>');
                        return;
                    }
                    var html = '';
                    res.data.forEach(function (item) {
                        var startVal = '';
                        var dtStart = null;
                        if (item.startTime) {
                            dtStart = new Date(item.startTime);
                            startVal = formatDateTimeLocal(dtStart);
                        }
                        var endVal = '';
                        var dtEnd = null;
                        if (item.endTime) {
                            dtEnd = new Date(item.endTime);
                            endVal = formatDateTimeLocal(dtEnd);
                        }
                        var durationText = calcDuration(dtStart, dtEnd);
                        html += '<tr>';
                        html += '    <td class="align-middle"><strong>' + htmlEncode(item.subjectName) + '</strong></td>';
                        html += '    <td><input type="datetime-local" class="form-control form-control-sm exam-time-start" data-subjectid="' + item.subjectId + '" value="' + startVal + '" /></td>';
                        html += '    <td><input type="datetime-local" class="form-control form-control-sm exam-time-end" data-subjectid="' + item.subjectId + '" value="' + endVal + '" /></td>';
                        html += '    <td class="align-middle text-center exam-time-duration">' + durationText + '</td>';
                        html += '</tr>';
                    });
                    $('#examTimeBody').html(html);
                    // 绑定时间变更自动计算时长
                    $('#examTimeBody').on('change', '.exam-time-start, .exam-time-end', function () {
                        var tr = $(this).closest('tr');
                        var startInput = tr.find('.exam-time-start').val();
                        var endInput = tr.find('.exam-time-end').val();
                        var dStart = startInput ? new Date(startInput) : null;
                        var dEnd = endInput ? new Date(endInput) : null;
                        tr.find('.exam-time-duration').text(calcDuration(dStart, dEnd));
                    });
                }).fail(function () {
                    $('#examTimeBody').html('<tr><td colspan="4" class="text-danger text-center py-4">网络错误，加载失败</td></tr>');
                });
            });

            function formatDateTimeLocal(dt) {
                if (!dt || isNaN(dt.getTime())) return '';
                var y = dt.getFullYear();
                var m = String(dt.getMonth() + 1).padStart(2, '0');
                var d = String(dt.getDate()).padStart(2, '0');
                var h = String(dt.getHours()).padStart(2, '0');
                var mi = String(dt.getMinutes()).padStart(2, '0');
                return y + '-' + m + '-' + d + 'T' + h + ':' + mi;
            }

            function calcDuration(startDt, endDt) {
                if (!startDt || !endDt || isNaN(startDt.getTime()) || isNaN(endDt.getTime())) {
                    return '<span class="text-muted">--</span>';
                }
                var diffMs = endDt.getTime() - startDt.getTime();
                if (diffMs <= 0) {
                    return '<span class="text-danger">无效</span>';
                }
                var hours = Math.floor(diffMs / (1000 * 60 * 60));
                var mins = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
                if (hours > 0) {
                    return hours + '时' + mins + '分';
                } else {
                    return mins + '分';
                }
            }

            $('#examTimeSave').click(function () {
                var btn = $(this).prop('disabled', true);
                var examId = parseInt($('#examTimeScheduleId').val());
                if (!examId) {
                    alert('数据错误');
                    btn.prop('disabled', false);
                    return;
                }
                var times = [];
                $('#examTimeBody tr').each(function () {
                    var startInput = $(this).find('.exam-time-start');
                    var endInput = $(this).find('.exam-time-end');
                    if (startInput.length === 0) return;
                    var subjectId = parseInt(startInput.data('subjectid'));
                    var startTime = startInput.val() || '';
                    var endTime = endInput.val() || '';
                    times.push({
                        subjectId: subjectId,
                        startTime: startTime,
                        endTime: endTime
                    });
                });

                $.ajax({
                    url: '@Url.Action("SaveExamSubjectTimes")?examScheduleId=' + examId,
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(times),
                    headers: { 'RequestVerificationToken': token },
                    success: function (res) {
                        btn.prop('disabled', false);
                        if (res.success) {
                            alert('考试时间保存成功！');
                            location.reload();
                        } else {
                            alert(res.message || '保存失败');
                        }
                    },
                    error: function () {
                        btn.prop('disabled', false);
                        alert('请求失败');
                    }
                });
            });
        });
    </script>
}
