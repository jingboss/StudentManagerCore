            // ---- 考试科目安排（考试维度） ----
            $(document).on('click', '.subject-btn', function () {
                var examId = $(this).data('id');
                var examName = $(this).data('name');
                var grades = $(this).data('grades') || '';
                $('#examSubjectTitle').text(examName);
                $('#examSubjectModal input[name="examScheduleId"]').val(examId);
                $('#examSubjectCheckList').html('<div class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-1"></span>加载中...</div>');

                // 根据年级名称判断学段
                function detectSchoolType(gradesStr) {
                    if (!gradesStr) return 'all';
                    var primaryGrades = '一年级,二年级,三年级,四年级,五年级,六年级';
                    var middleGrades = '七年级,八年级,九年级';
                    var hasPrimary = false, hasMiddle = false;
                    var items = gradesStr.split(',');
                    items.forEach(function(g) {
                        g = g.trim();
                        if (primaryGrades.indexOf(g) >= 0) hasPrimary = true;
                        if (middleGrades.indexOf(g) >= 0) hasMiddle = true;
                    });
                    if (hasPrimary && !hasMiddle) return 'primary';
                    if (hasMiddle && !hasPrimary) return 'middle';
                    return 'all';
                }
                var schoolType = detectSchoolType(grades);

                $.get('@Url.Action("GetSubjects")', function (allSubjects) {
                    // 标准化科目数据（兼容大小写）
                    allSubjects = allSubjects.map(function(s) {
                        return {
                            id: s.id || s.Id,
                            name: s.name || s.Name,
                            grade: s.grade || s.Grade || '',
                            fullScore: s.fullScore != null ? s.fullScore : (s.FullScore != null ? s.FullScore : null)
                        };
                    });
                    // 按学段过滤
                    var filtered = allSubjects;
                    if (schoolType === 'primary') {
                        // 小学：只显示"无年级"或年级名含"小"或年级名以"一"/"二"/"三"/"四"/"五"/"六"开头的科目
                        filtered = allSubjects.filter(function(s) {
                            if (!s.grade) return true; // 无年级限制 = 全校适用
                            if (s.grade.indexOf('小') >= 0) return true;
                            var firstChar = s.grade.trim().charAt(0);
                            return '一二三四五六'.indexOf(firstChar) >= 0;
                        });
                    } else if (schoolType === 'middle') {
                        // 初中：只显示"无年级"或年级名含"初"或年级名以"七"/"八"/"九"开头的科目
                        filtered = allSubjects.filter(function(s) {
                            if (!s.grade) return true; // 无年级限制 = 全校适用
                            if (s.grade.indexOf('初') >= 0) return true;
                            var firstChar = s.grade.trim().charAt(0);
                            return '七八九'.indexOf(firstChar) >= 0;
                        });
                    }

                    $.get('@Url.Action("GetExamSubjects")', { examScheduleId: examId }, function (examSubjects) {
                        var checkedIds = examSubjects.map(function(e) { return e.subjectId; });
                        var fullScoreMap = {};
                        examSubjects.forEach(function(e) { if (e.fullScore) fullScoreMap[e.subjectId] = e.fullScore; });

                        var html = '';
                        // 调试信息：显示科目总数和过滤后数量
                        html += '<div class="small text-muted mb-2">共 ' + allSubjects.length + ' 科，筛选后 ' + filtered.length + ' 科</div>';
                        if (filtered.length === 0) {
                            html = '<div class="text-muted text-center py-3">暂无可选科目</div>';
                        } else if (schoolType === 'primary') {
                            // 小学 - 合并同名同分科目（小学各年级科目/总分一致，合并避免重复）
                            var mergeOrder = [];
                            var mergeMap = {};
                            filtered.forEach(function (subj) {
                                var key = subj.name + '|' + (subj.fullScore || 100);
                                if (!mergeMap[key]) {
                                    mergeMap[key] = { name: subj.name, fullScore: subj.fullScore || 100, ids: [], grades: [] };
                                    mergeOrder.push(key);
                                }
                                mergeMap[key].ids.push(subj.id);
                                if (subj.grade) mergeMap[key].grades.push(subj.grade);
                            });

                            mergeOrder.forEach(function (key) {
                                var m = mergeMap[key];
                                // 合并组内所有 subjectId 都已分配才算 checked
                                var allChecked = m.ids.every(function (id) { return checkedIds.indexOf(id) >= 0; });
                                // 优先取已保存的满分，否则用合并组的公共满分
                                var fs = m.fullScore;
                                for (var i = 0; i < m.ids.length; i++) {
                                    if (fullScoreMap[m.ids[i]]) { fs = fullScoreMap[m.ids[i]]; break; }
                                }
                                html += '<div class="form-check form-check-inline mb-1" style="min-width:170px;">';
                                html += '    <input class="form-check-input exam-subject-check" type="checkbox" value="' + m.ids.join(',') + '" data-merged="1"' + (allChecked ? ' checked' : '') + ' />';
                                html += '    <label class="form-check-label me-1">' + htmlEncode(m.name) + '</label>';
                                html += '    <input type="number" class="form-control form-control-sm exam-subject-fullscore d-inline-block" style="width:58px;display:inline!important;" value="' + fs + '" min="1" />';
                                html += '    <small class="text-muted">分</small>';
                                html += '</div>';
                            });
                        } else {
                            // 初中或混合 - 合并同名科目（去重）
                            var mergeOrder = [];
                            var mergeMap = {};
                            filtered.forEach(function (subj) {
                                var key = subj.name + '|' + (subj.fullScore || 100);
                                if (!mergeMap[key]) {
                                    mergeMap[key] = { name: subj.name, fullScore: subj.fullScore || 100, ids: [], grades: [] };
                                    mergeOrder.push(key);
                                }
                                mergeMap[key].ids.push(subj.id);
                                if (subj.grade) mergeMap[key].grades.push(subj.grade);
                            });

                            mergeOrder.forEach(function (key) {
                                var m = mergeMap[key];
                                // 合并组内所有 subjectId 都已分配才算 checked
                                var allChecked = m.ids.every(function (id) { return checkedIds.indexOf(id) >= 0; });
                                // 优先取已保存的满分，否则用合并组的公共满分
                                var fs = m.fullScore;
                                for (var i = 0; i < m.ids.length; i++) {
                                    if (fullScoreMap[m.ids[i]]) { fs = fullScoreMap[m.ids[i]]; break; }
                                }
                                html += '<div class="form-check form-check-inline mb-1" style="min-width:170px;">';
                                html += '    <input class="form-check-input exam-subject-check" type="checkbox" value="' + m.ids.join(',') + '" data-merged="1"' + (allChecked ? ' checked' : '') + ' />';
                                html += '    <label class="form-check-label me-1">' + htmlEncode(m.name) + '</label>';
                                html += '    <input type="number" class="form-control form-control-sm exam-subject-fullscore d-inline-block" style="width:58px;display:inline!important;" value="' + fs + '" min="1" />';
                                html += '    <small class="text-muted">分</small>';
                                html += '</div>';
                            });
                        }
                        $('#examSubjectCheckList').html(html);
                        $('#examSubjectModal').modal('show');
                    });
                });
            });

            $('#examSubjSelectAll').click(function () {
