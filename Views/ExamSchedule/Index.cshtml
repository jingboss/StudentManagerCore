@{
    ViewBag.Title = "考试安排管理";
    var schedules = Model as List<ExamSchedule> ?? new();
    var semesters = ViewBag.Semesters as IEnumerable<dynamic> ?? new List<dynamic>();
    var grades = ViewBag.Grades as IEnumerable<dynamic> ?? new List<object>();
    var allSubjects = ViewBag.AllSubjects as List<Subject> ?? new();
    var examTypes = new[] { "期中", "期末", "月考", "单元测试", "模拟考" };
    var statusList = new[] { "未开始", "进行中", "已结束" };
}

<div class="container-fluid">
    <h4 class="mb-3"><i class="bi bi-calendar-event me-2"></i>考试安排管理</h4>

    <!-- 搜索筛选栏 -->
    <div class="card bg-light mb-3">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="small text-muted mb-1">考试名称</label>
                    <input type="text" name="keyword" class="form-control form-control-sm" placeholder="搜索考试名称" value="@ViewBag.Keyword" />
                </div>
                <div class="col-auto">
                    <label class="small text-muted mb-1">考试类型</label>
                    <select name="examType" class="form-select form-select-sm">
                        <option value="">全部</option>
                        @foreach (var t in examTypes)
                        {
                            <option value="@t" selected="@(ViewBag.FilterExamType == t)">@t</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="small text-muted mb-1">状态</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="">全部</option>
                        @foreach (var st in statusList)
                        {
                            <option value="@st" selected="@(ViewBag.FilterStatus == st)">@st</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>搜索</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">重置</a>
                </div>
            </form>
        </div>
    </div>

    <div class="d-flex justify-content-end mb-2">
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="bi bi-plus-circle me-1"></i>新增考试安排
        </button>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>考试名称</th>
                        <th>考试类型</th>
                        <th>适用年级</th>
                        <th>考试日期段</th>
                        <th>关联学期</th>
                        <th>状态</th>
                        <th>考试科目</th>
                        <th>负责人</th>
                        <th>创建时间</th>
                        <th style="width:100px">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (schedules.Count == 0)
                    {
                        <tr><td colspan="10" class="text-center text-muted py-3">暂无考试安排</td></tr>
                    }
                    @foreach (var s in schedules)
                    {
                        var subjectNames = s.ExamSubjects?.Where(es => es.Subject != null).Select(es => es.Subject!.Name).Distinct().ToList() ?? new();
                        var subjectIds = s.ExamSubjects?.Select(es => es.SubjectId).ToList() ?? new();
                        var effectiveEndDate = s.EndDate ?? s.ExamDate;
                        var isDatePast = effectiveEndDate.Date < DateTime.Now.Date;
                        var rowClass = isDatePast && s.Status != "已结束" ? "table-warning" : "";
                        var dateDisplay = s.EndDate.HasValue
                            ? s.ExamDate.ToString("yyyy-MM-dd") + " 至 " + s.EndDate.Value.ToString("yyyy-MM-dd")
                            : s.ExamDate.ToString("yyyy-MM-dd");
                        <tr class="@rowClass">
                            <td>
                                <span class="fw-bold">@s.Name</span>
                                @if (isDatePast && s.Status != "已结束")
                                {
                                    <span class="badge bg-danger ms-1" title="考试日期已过但状态未更新">!</span>
                                }
                            </td>
                            <td><span class="badge bg-info">@s.ExamType</span></td>
                            <td>@(s.Grades ?? "全部年级")</td>
                            <td>@dateDisplay</td>
                            <td>@(s.Semester?.AcademicYear?.YearName + " " + s.Semester?.SemesterName)</td>
                            <td>
                                @if (s.Status == "未开始") { <span class="badge bg-secondary">未开始</span> }
                                else if (s.Status == "进行中") { <span class="badge bg-success">进行中</span> }
                                else { <span class="badge bg-warning text-dark">已结束</span> }
                            </td>
                            <td>
                                @if (subjectNames.Any()) { @string.Join("、", subjectNames) }
                                else { <span class='text-muted'>未设置科目</span> }
                            </td>
                            <td>
                                @{
                                    var examTeachers = (ViewBag.AllExamTeachers as IEnumerable<ExamSubjectTeacher> ?? Enumerable.Empty<ExamSubjectTeacher>())
                                        .Where(est => est.ExamScheduleId == s.Id)
                                        .ToList();
                                    var teacherInfo = new List<string>();
                                    if (examTeachers.Any())
                                    {
                                        // 负责人是考试级别，直接显示去重后的人名
                                        teacherInfo = examTeachers
                                            .Where(et => et.Admin != null)
                                            .Select(et => et.Admin!.RealName!)
                                            .Distinct()
                                            .ToList();
                                    }
                                }
                                @if (teacherInfo.Any())
                                {
                                    <span class="small">@string.Join("、", teacherInfo)</span>
                                }
                                else
                                {
                                    <span class='text-muted small'>未分配</span>
                                }
                            </td>
                            <td class="small text-muted">@s.CreateTime.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <button class="btn btn-outline-primary btn-sm edit-btn" data-id="@s.Id"
                                        data-name="@s.Name" data-examtype="@s.ExamType"
                                        data-grades="@s.Grades" data-examdate="@s.ExamDate.ToString("yyyy-MM-dd")"
                                        data-enddate="@(s.EndDate?.ToString("yyyy-MM-dd") ?? "")"
                                        data-semesterid="@s.SemesterId" data-status="@s.Status"
                                        data-subjectids="@string.Join(",", subjectIds)"
                                        title="编辑"><i class="bi bi-pencil"></i></button>
                                <a asp-controller="ExamRoom" asp-action="Index" asp-route-examScheduleId="@s.Id"
                                   class="btn btn-outline-success btn-sm" title="考场管理">
                                    <i class="bi bi-building"></i>
                                </a>
                                <button class="btn btn-outline-info btn-sm assign-teacher-btn"
                                        data-examscheduleid="@s.Id" data-examname="@s.Name"
                                        title="分配负责人">
                                    <i class="bi bi-person-plus"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm delete-btn" data-id="@s.Id" data-name="@s.Name" title="删除"><i class="bi bi-trash"></i></button>
                                <button class="btn btn-outline-secondary btn-sm subject-btn" data-id="@s.Id" data-name="@s.Name" data-grades="@s.Grades" title="考试科目安排">
                                    <i class="bi bi-book me-1"></i>科目
                                </button>
                                <button class="btn btn-outline-warning btn-sm exam-time-btn" data-id="@s.Id" data-name="@s.Name" title="考试时间设置">
                                    <i class="bi bi-clock me-1"></i>考试时间
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 新增 Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form id="addForm" onsubmit="return false;">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">新增考试安排</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">考试名称<span class="text-danger">*</span></label>
                        <input name="name" class="form-control" placeholder="如：2024学年第一学期期中考试" required />
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">考试类型</label>
                            <select name="examType" class="form-select">
                                @foreach (var t in examTypes)
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">开始日期</label>
                            <input name="examDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">结束日期</label>
                            <input name="endDate" type="date" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">适用年级（不选则全部年级）</label>
                        <div class="border rounded p-2" style="max-height:150px;overflow-y:auto;">
                            @if (grades.Any())
                            {
                                foreach (var g in grades)
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input grade-check" type="checkbox" name="gradeItem" value="@g.Value" />
                                        <label class="form-check-label">@g.Text</label>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-muted small">暂无年级数据，请先在年级管理中设置年级</div>
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">关联学期</label>
                            <select name="semesterId" class="form-select" required>
                                <option value="">-- 请选择学期 --</option>
                                @foreach (var sem in semesters)
                                {
                                    <option value="@sem.Id">@sem.Display</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">状态</label>
                            <select name="status" class="form-select">
                                @foreach (var st in statusList)
                                {
                                    <option value="@st">@st</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="button" class="btn btn-primary" id="addSubmit">保存</button>
                </div>
            </form>
        </div>
    </div>
</div>

