                $.ajax({
                    url: '@Url.Action("SaveExamSubjects")?examScheduleId=' + examScheduleId,
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(subjects),
                    headers: { 'RequestVerificationToken': token },
                    success: function (res) {
