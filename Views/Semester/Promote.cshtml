@{
    ViewBag.Title = "学生升级管理";
    var grades = ViewBag.Grades as IEnumerable<dynamic> ?? new List<object>();
}

@Html.AntiForgeryToken()

<div class="container-fluid">
    <h4 class="mb-3"><i class="bi bi-arrow-up-circle me-2"></i>学生升级 / 毕业管理</h4>

    <div class="row g-3">
        <!-- 升级 -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-warning bg-opacity-10">
                    <h6 class="mb-0"><i class="bi bi-arrow-up me-1 text-warning"></i>升级学生</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted small">选择要升级的年级，系统会将所有在读学生升到下一个年级。</p>
                    <div class="mb-3">
                        <label class="form-label">选择年级</label>
                        <select id="promoteGrade" class="form-select">
                            <option value="">-- 请选择 --</option>
                            @foreach (var g in grades)
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                    </div>
                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle me-1"></i>
                        一年级 → 二年级 → ... → 六年级 → 七年级 → 八年级 → 九年级
                    </div>
                    <button type="button" class="btn btn-warning" id="btnPromote">
                        <i class="bi bi-arrow-up me-1"></i>执行升级
                    </button>
                    <div id="promoteResult" class="mt-2"></div>
                </div>
            </div>
        </div>

        <!-- 毕业 -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-info bg-opacity-10">
                    <h6 class="mb-0"><i class="bi bi-mortarboard me-1 text-info"></i>毕业归档</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted small">选择要毕业的年级，系统会将所有在读学生标记为"已毕业"。</p>
                    <div class="mb-3">
                        <label class="form-label">选择年级</label>
                        <select id="graduateGrade" class="form-select">
                            <option value="">-- 请选择 --</option>
                            @foreach (var g in grades)
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                    </div>
                    <div class="alert alert-warning small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        毕业操作不可逆，已毕业的学生将不再显示在活跃学生列表中。
                    </div>
                    <button type="button" class="btn btn-info text-white" id="btnGraduate">
                        <i class="bi bi-mortarboard me-1"></i>执行毕业
                    </button>
                    <div id="graduateResult" class="mt-2"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>返回学期管理
        </a>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            var token = $('input[name="__RequestVerificationToken"]').val();

            // 升级
            $('#btnPromote').click(function () {
                var grade = $('#promoteGrade').val();
                if (!grade) { alert('请选择年级'); return; }

                var $btn = $(this);
                var $result = $('#promoteResult');
                showConfirm('确定将「' + grade + '」所有在读学生升级？', function() {
                    $btn.prop('disabled', true);
                    $result.html('<div class="spinner-border spinner-border-sm me-1"></div>处理中...');

                    $.post('@Url.Action("DoPromote")', { fromGrade: grade, __RequestVerificationToken: token }, function (res) {
                        if (res.success) {
                            $result.html('<div class="alert alert-success mt-2 mb-0">' + res.message + '</div>');
                            setTimeout(function () { location.reload(); }, 2000);
                        } else {
                            $result.html('<div class="alert alert-danger mt-2 mb-0">' + res.message + '</div>');
                            $btn.prop('disabled', false);
                        }
                    }).fail(function () {
                        $result.html('<div class="alert alert-danger mt-2 mb-0">操作失败</div>');
                        $btn.prop('disabled', false);
                    });
                });
            });

            // 毕业
            $('#btnGraduate').click(function () {
                var grade = $('#graduateGrade').val();
                if (!grade) { alert('请选择年级'); return; }

                var $btn = $(this);
                var $result = $('#graduateResult');
                showConfirm('确定将「' + grade + '」所有在读学生标记为已毕业？此操作不可逆！', function() {
                    $btn.prop('disabled', true);
                    $result.html('<div class="spinner-border spinner-border-sm me-1"></div>处理中...');

                    $.post('@Url.Action("DoGraduate")', { fromGrade: grade, __RequestVerificationToken: token }, function (res) {
                        if (res.success) {
                            $result.html('<div class="alert alert-success mt-2 mb-0">' + res.message + '</div>');
                            setTimeout(function () { location.reload(); }, 2000);
                        } else {
                            $result.html('<div class="alert alert-danger mt-2 mb-0">' + res.message + '</div>');
                            $btn.prop('disabled', false);
                        }
                    }).fail(function () {
                        $result.html('<div class="alert alert-danger mt-2 mb-0">操作失败</div>');
                        $btn.prop('disabled', false);
                    });
                });
            });
        });
    </script>
}
