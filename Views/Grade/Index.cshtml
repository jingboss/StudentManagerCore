@model IEnumerable<StudentManagerCore.Models.GradeLevel>
@{
    ViewData["Title"] = "班级管理";
    var years = ViewBag.Years as List<int> ?? new List<int>();
    var currentYear = DateTime.Now.Year;
    var studentCounts = ViewBag.StudentCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
    var gradeStudentCounts = ViewBag.GradeStudentCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">
        <i class="bi bi-diagram-3-fill me-2"></i>班级管理
    </h4>
</div>

<!-- 提示消息 -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- 新增年级 -->
<div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white">
        <i class="bi bi-plus-circle me-1"></i>新增年级
    </div>
    <div class="card-body">
        <form method="post" asp-action="AddGrade" class="row g-3 align-items-end" id="addGradeForm">
            @Html.AntiForgeryToken()
            <div class="col-md-4">
                <label class="form-label">学段</label>
                <select name="schoolType" class="form-select" id="schoolTypeSelect">
                    <option value="小学">小学</option>
                    <option value="初中">初中</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">年级</label>
                <select name="gradeName" class="form-select" id="gradeNameSelect">
                    <option value="">-- 请选择年级 --</option>
                    <option value="一年级">一年级</option>
                    <option value="二年级">二年级</option>
                    <option value="三年级">三年级</option>
                    <option value="四年级">四年级</option>
                    <option value="五年级">五年级</option>
                    <option value="六年级">六年级</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-plus-lg me-1"></i>添加年级
                </button>
            </div>
        </form>
    </div>
</div>

<!-- 年级列表 -->
@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        <span>暂无年级数据，请在上方添加</span>
    </div>
}

<div class="accordion" id="gradeAccordion">
    @{
        int idx = 0;
    }
    @foreach (var grade in Model)
    {
        idx++;
        var collapseId = "collapse" + idx;
        var headingId = "heading" + idx;
        var classCount = grade.Classes?.Count ?? 0;

        <div class="accordion-item mb-2 border rounded">
            <h2 class="accordion-header" id="@headingId">
                <button class="accordion-button @(idx > 1 ? "collapsed" : "")" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                    <span class="fw-bold me-3">@grade.CurrentGradeName</span>
                    <span class="badge bg-secondary me-2">@classCount 个班</span>
                    @{
                    var gKey = grade.SchoolType + "|" + grade.EntryYear;
                    var gCount = gradeStudentCounts.ContainsKey(gKey) ? gradeStudentCounts[gKey] : 0;
                    }
                    <span class="badge bg-success me-2">在读 @gCount 人</span>
                </button>
            </h2>
            <div id="@collapseId" class="accordion-collapse collapse @(idx == 1 ? "show" : "")" data-bs-parent="#gradeAccordion">
                <div class="accordion-body">
                    <!-- 班级列表 -->
                    @if (classCount > 0)
                    {
                        <div class="mb-3">
                            <table class="table table-sm table-bordered align-middle" style="font-size:0.9rem;">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width:35%;">班级名称</th>
                                        <th style="width:15%;">在读人数</th>
                                        <th style="width:18%;">当前班主任</th>
                                        <th style="width:25%;">创建时间</th>
                                        <th style="width:7%;">操作</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cls in grade.Classes!)
                                    {
                                        <tr>
                                            <td><i class="bi bi-people-fill me-2 text-primary"></i>@grade.CurrentGradeName@cls.ClassName</td>
                                            <td>
                                                @{
                    var scKey = grade.SchoolType + "|" + grade.EntryYear + "|" + cls.ClassName;
                    var sc = studentCounts.ContainsKey(scKey) ? studentCounts[scKey] : 0;
                                                }
                                                <span class="badge bg-@(sc > 0 ? "success" : "secondary") rounded-pill">@sc</span>
                                            </td>
                                            <td>
                                                @{
                                                    var tName = ViewBag.TeacherNames != null && ViewBag.TeacherNames.ContainsKey(cls.ClassInfoID)
                                                        ? ViewBag.TeacherNames[cls.ClassInfoID] : "";
                                                }
                                                @if (!string.IsNullOrEmpty(tName))
                                                {
                                                    <span class="badge bg-info text-dark"><i class="bi bi-person-check me-1"></i>@tName</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">未设置</span>
                                                }
                                            </td>
                                            <td class="text-muted">@cls.CreateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                <button type="button" class="btn btn-outline-warning btn-sm me-1" title="添加班主任"
                                                        onclick="assignTeacher(@cls.ClassInfoID, '@(grade.CurrentGradeName + cls.ClassName)')">
                                                    <i class="bi bi-person-plus"></i>
                                                </button>
                                                <form method="post" asp-action="DeleteClass" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@cls.ClassInfoID" />
                                                    <button type="button" class="btn btn-outline-danger btn-sm"
                                                            onclick="showConfirm('确认删除 @(grade.CurrentGradeName)@(cls.ClassName)？', function(){ $(this).closest('form').submit(); }.bind(this))">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                                @{
                                                    var hasTeacher = ViewBag.TeacherNames != null && ViewBag.TeacherNames.ContainsKey(cls.ClassInfoID);
                                                }
                                                @if (hasTeacher)
                                                {
                                                    <form method="post" asp-action="RemoveTeacher" style="display:inline;" class="ms-1">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="classId" value="@cls.ClassInfoID" />
                                                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                                                onclick="showConfirm('确认取消 @(grade.CurrentGradeName)@(cls.ClassName) 的班主任？', function(){ $(this).closest('form').submit(); }.bind(this))">
                                                            <i class="bi bi-person-x"></i> 取消班主任
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small mb-3"><i class="bi bi-info-circle me-1"></i>暂无班级，请在下方添加</div>
                    }

                    <!-- 新增班级 -->
                    <form method="post" asp-action="AddClass" class="row g-2 align-items-end">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="gradeLevelId" value="@grade.GradeLevelID" />
                        <div class="col-md-4">
                            <label class="form-label small">班级名称</label>
                            <input type="text" name="className" class="form-control form-control-sm" placeholder="例如：一班" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small">或数量</label>
                            <input type="number" name="count" class="form-control form-control-sm" min="1" max="50" value="1" />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-success btn-sm w-100">
                                <i class="bi bi-plus-circle me-1"></i>添加班级
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-info btn-sm w-100" onclick="this.form.count.value=5">
                                <i class="bi bi-lightning me-1"></i>快速5个班
                            </button>
                        </div>
                    </form>

                    <!-- 删除年级 -->
                    <div class="mt-3 text-end">
                        <form method="post" asp-action="DeleteGrade" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@grade.GradeLevelID" />
                            <button type="button" class="btn btn-outline-danger btn-sm"
                                    onclick="showConfirm('确认删除 @(grade.CurrentGradeName)？将同时删除其下所有班级和关联数据！', function(){ $(this).closest('form').submit(); }.bind(this))">
                                <i class="bi bi-trash me-1"></i>删除该年级
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- 选择班主任弹窗 -->
<div class="modal fade" id="teacherModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>添加班主任</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted" id="teacherModalClass"></p>
                <div class="mb-3">
                    <label class="form-label">搜索班主任</label>
                    <div class="input-group">
                        <input type="text" id="teacherSearch" class="form-control" placeholder="输入姓名或手机号搜索..." />
                        <button class="btn btn-primary" type="button" id="btnSearchTeacher">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
                <div id="teacherResults" class="list-group" style="max-height:300px;overflow-y:auto;">
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-search me-1"></i>输入关键字搜索
                    </div>
                </div>
                <div id="teacherNoData" class="text-muted small d-none">
                    <i class="bi bi-info-circle me-1"></i>暂无可用的班主任，请先在 教职工管理 中添加角色为"班主任"的用户
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 学段切换 → 年级选项切换
        const primaryGrades = ['一年级', '二年级', '三年级', '四年级', '五年级', '六年级'];
        const middleGrades = ['七年级', '八年级', '九年级'];

        document.getElementById('schoolTypeSelect')?.addEventListener('change', function () {
            var sel = document.getElementById('gradeNameSelect');
            sel.innerHTML = '<option value="">-- 请选择年级 --</option>';
            var grades = this.value === '初中' ? middleGrades : primaryGrades;
            grades.forEach(function (g) {
                var opt = document.createElement('option');
                opt.value = g;
                opt.textContent = g;
                sel.appendChild(opt);
            });
        });
    </script>
    <script>
        var currentClassId = 0;
        var currentClassName = '';
        var searchTimer = null;

        function assignTeacher(classId, className) {
            currentClassId = classId;
            currentClassName = className;
            $('#teacherModalClass').text('班级：' + className);
            $('#teacherSearch').val('').focus();
            $('#teacherResults').html('<div class="text-center text-muted py-3"><i class="bi bi-search me-1"></i>输入关键字搜索</div>');
            $('#teacherNoData').addClass('d-none');
            $('#teacherModal').modal('show');
        }

        function doSearch() {
            var keyword = $('#teacherSearch').val().trim();
            if (!keyword) {
                $('#teacherResults').html('<div class="text-center text-muted py-3"><i class="bi bi-search me-1"></i>输入关键字搜索</div>');
                return;
            }

            $('#teacherResults').html('<div class="text-center py-2"><div class="spinner-border spinner-border-sm text-primary"></div> 搜索中...</div>');

            $.get('@Url.Action("SearchTeachers", "Grade")', { keyword: keyword }, function (data) {
                if (data && data.length > 0) {
                    var html = '';
                    $.each(data, function (i, t) {
                        html += '<div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">';
                        html += '<div><strong>' + t.realName + '</strong>';
                        if (t.phone) html += '<br><small class="text-muted">' + t.phone + '</small>';
                        html += '</div>';
                        html += '<button class="btn btn-warning btn-sm apply-teacher" data-id="' + t.adminID + '"><i class="bi bi-check-lg me-1"></i>应用</button>';
                        html += '</div>';
                    });
                    $('#teacherResults').html(html);
                    $('#teacherNoData').addClass('d-none');
                } else {
                    $('#teacherResults').html('<div class="text-center text-muted py-3"><i class="bi bi-inbox me-1"></i>未找到匹配的班主任</div>');
                    $('#teacherNoData').removeClass('d-none');
                }
            });
        }

        // 搜索按钮点击
        $('#btnSearchTeacher').click(doSearch);

        // 回车搜索
        $('#teacherSearch').keydown(function (e) {
            if (e.keyCode === 13) {
                e.preventDefault();
                doSearch();
            }
        });

        // 应用按钮（委托事件）
        $(document).on('click', '.apply-teacher', function () {
            var teacherId = $(this).data('id');
            var teacherName = $(this).closest('.list-group-item').find('strong').text();
            var btn = $(this);

            showConfirm('确定将「' + teacherName + '」设置为「' + currentClassName + '」的班主任吗？', function () {
                $.post('@Url.Action("AssignTeacher", "Grade")', {
                    classId: currentClassId,
                    teacherId: teacherId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val()
                }, function (res) {
                    if (res.success) {
                        $('#teacherModal').modal('hide');
                        location.reload();
                    } else {
                        alert(res.message || '操作失败');
                    }
                });
            });
        });
    </script>
}
