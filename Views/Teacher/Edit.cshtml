@model Admin
@{
    ViewData["Title"] = "编辑教职工";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>编辑教职工</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="Edit">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="AdminID" />

                <!-- 1. 基本信息 -->
                <h6 class="border-bottom pb-2 mb-3 text-primary">
                    <i class="bi bi-info-circle me-1"></i>基本信息
                </h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">姓名 <span class="text-danger">*</span></label>
                        <input asp-for="RealName" class="form-control" required />
                        <span asp-validation-for="RealName" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">性别</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">-- 请选择 --</option>
                            <option value="男">男</option>
                            <option value="女">女</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">民族</label>
                        <input asp-for="Nation" class="form-control" placeholder="如：汉族" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">出生日期</label>
                        <input asp-for="BirthDate" class="form-control" type="date" />
                    </div>
                </div>

                <!-- 2. 联系信息 -->
                <h6 class="border-bottom pb-2 mb-3 mt-4 text-primary">
                    <i class="bi bi-telephone me-1"></i>联系信息
                </h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">手机号 <span class="text-danger">*</span></label>
                        <input asp-for="Phone" class="form-control" required />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">户口所在地</label>
                        <input asp-for="RegisteredDomicile" class="form-control" />
                    </div>
                </div>

                <!-- 3. 学历/资格信息 -->
                <h6 class="border-bottom pb-2 mb-3 mt-4 text-primary">
                    <i class="bi bi-mortarboard me-1"></i>学历与资格
                </h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-3">
                        <label class="form-label">最高学历</label>
                        <select asp-for="HighestEducation" class="form-select">
                            <option value="">-- 请选择 --</option>
                            <option value="中专">中专</option>
                            <option value="大专">大专</option>
                            <option value="本科">本科</option>
                            <option value="硕士">硕士</option>
                            <option value="博士">博士</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">教师资格证科目</label>
                        <input asp-for="CertSubject" class="form-control" placeholder="如：小学语文" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">教师资格证号</label>
                        <input asp-for="CertNumber" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">所属教育局</label>
                        <input asp-for="CertAuthority" class="form-control" />
                    </div>
                </div>

                <!-- 4. 岗位信息 -->
                <h6 class="border-bottom pb-2 mb-3 mt-4 text-primary">
                    <i class="bi bi-briefcase me-1"></i>岗位信息
                </h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">学段</label>
                        <select asp-for="SchoolType" class="form-select">
                            <option value="">-- 请选择 --</option>
                            <option value="小学">小学</option>
                            <option value="初中">初中</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">角色 <span class="text-danger">*</span></label>
                        <div class="dropdown" id="editRoleDropdown">
                            <button class="btn btn-light border form-control text-start d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span id="editRoleDisplay" class="text-muted small">请选择角色（可多选）</span>
                                <span class="caret">&#9660;</span>
                            </button>
                            <ul class="dropdown-menu p-2 w-100" style="max-height:260px;overflow-y:auto;" id="editRoleMenu">
                                @{
                                    var currentRoles = Model.RoleList;
                                    var roleCount = currentRoles.Count;
                                }
                                <li><label class="dropdown-item d-flex align-items-center gap-2 py-1"><input type="checkbox" class="form-check-input edit-role-cb" value="班主任" @(currentRoles.Contains("班主任")?"checked":"")> <span>🔵 班主任</span></label></li>
                                <li><label class="dropdown-item d-flex align-items-center gap-2 py-1"><input type="checkbox" class="form-check-input edit-role-cb" value="科任教师" @(currentRoles.Contains("科任教师")?"checked":"")> <span>🟢 科任教师</span></label></li>
                                <li><label class="dropdown-item d-flex align-items-center gap-2 py-1"><input type="checkbox" class="form-check-input edit-role-cb" value="年级级长" @(currentRoles.Contains("年级级长")?"checked":"")> <span>🟣 年级级长</span></label></li>
                                <li><label class="dropdown-item d-flex align-items-center gap-2 py-1"><input type="checkbox" class="form-check-input edit-role-cb" value="教务主任" @(currentRoles.Contains("教务主任")?"checked":"")> <span>🟠 教务主任</span></label></li>
                                <li><label class="dropdown-item d-flex align-items-center gap-2 py-1"><input type="checkbox" class="form-check-input edit-role-cb" value="校长" @(currentRoles.Contains("校长")?"checked":"")> <span>🔴 校长</span></label></li>
                                <li><label class="dropdown-item d-flex align-items-center gap-2 py-1"><input type="checkbox" class="form-check-input edit-role-cb" value="后勤主任" @(currentRoles.Contains("后勤主任")?"checked":"")> <span>🛠 后勤主任</span></label></li>
                            </ul>
                        </div>
                        <input type="hidden" name="Role" id="editRoleHidden" value="@Model.Role" />
                    </div>
                    <!-- 年级/班级（班主任时才显示） -->
                    <div class="col-md-4" id="editGradeGroup" style="display:none;">
                        <label class="form-label">年级</label>
                        <select asp-for="Grade" class="form-select" id="editGradeSelect">
                            <option value="">-- 请选择 --</option>
                            @foreach (var g in ViewBag.GradeList as IEnumerable<dynamic> ?? new List<object>())
                            {
                                <option value="@g.Value" data-schooltype="@g.SchoolType" selected="@(Model.Grade == g.Value)">@g.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4" id="editClassGroup" style="display:none;">
                        <label class="form-label">班级</label>
                        <select asp-for="ClassName" class="form-select" id="editClassSelect" data-currentclass="@Model.ClassName">
                            <option value="">-- 请先选择年级 --</option>
                        </select>
                    </div>
                </div>

                <!-- 所教科目（联动学段） -->
                <div class="row mb-3" id="editSubjectGroup" style="display:none;">
                    <div class="col-12">
                        <label class="form-label fw-bold">所教科目</label>
                        <div id="editSubjectCheckList" class="d-flex flex-wrap gap-2 border rounded p-2 bg-light" style="min-height:38px;">
                            <span class="text-muted small">请先选择学段</span>
                        </div>
                    </div>
                </div>

                <hr />
                <div class="text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary me-2">
                        <i class="bi bi-x-lg me-1"></i>取消
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-lg me-1"></i>保存
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // 角色下拉多选：更新隐藏字段和按钮文字
    $(document).on('change', '#editModalBody .edit-role-cb', function() {
        syncEditModalRoles();
    });

    function syncEditModalRoles() {
        var checked = $('#editModalBody .edit-role-cb:checked');
        var roles = checked.map(function() { return $(this).val(); }).get();
        $('#editModalBody #editRoleHidden').val(roles.join(','));
        if (roles.length > 0) {
            $('#editModalBody #editRoleDisplay').text('已选 ' + roles.length + ' 个角色').removeClass('text-muted');
        } else {
            $('#editModalBody #editRoleDisplay').text('请选择角色（可多选）').addClass('text-muted');
        }
        // 班主任联动
        if (roles.indexOf('班主任') >= 0) {
            $('#editModalBody #editGradeGroup, #editModalBody #editClassGroup').show();
            var st = $('#editModalBody select[name="SchoolType"]').val();
            var gr = $('#editModalBody #editGradeSelect').val();
            if (st && gr) triggerEditLoadClasses(st, gr, true);
        } else {
            $('#editModalBody #editGradeGroup, #editModalBody #editClassGroup').hide();
        }
    }

    // 学段联动：过滤年级 + 加载对应科目（编辑）
    $(document).on('change', '#editModalBody select[name="SchoolType"]', function() {
        var type = $(this).val();
        var adminId = $('#editModalBody #AdminID').val();
        // 过滤年级下拉
        var $gradeSel = $('#editModalBody #editGradeSelect');
        $gradeSel.val('');
        $gradeSel.find('option').each(function() {
            if (!$(this).val()) return;
            var st = $(this).data('schooltype');
            $(this).toggle(!type || st === type);
        });
        // 清空班级
        $('#editModalBody #editClassSelect').html('<option value="">-- 请先选择年级 --</option>');
        // 加载科目
        var $group = $('#editSubjectGroup');
        var $list = $('#editSubjectCheckList');
        if (!type) { $group.hide(); return; }
        $group.show();
        $list.html('<span class="text-muted small"><span class="spinner-border spinner-border-sm"></span> 加载科目...</span>');
        $.get('@Url.Action("GetSubjectsByType", "Teacher")', { type: type }, function(data) {
            if (data.length === 0) {
                $list.html('<span class="text-muted small">暂无可用科目</span>');
                return;
            }
            $.get('@Url.Action("GetTeacherSubjects", "Teacher")', { adminId: adminId }, function(checkedIds) {
                var html = '';
                data.forEach(function(s) {
                    var checked = checkedIds.indexOf(s.id) >= 0 ? ' checked' : '';
                    html += '<label class="form-check-label me-1" style="cursor:pointer;background:#fff;padding:4px 12px;border:1px solid #dee2e6;border-radius:4px;">';
                    html += '<input type="checkbox" class="form-check-input me-1 edit-subject-cb" value="' + s.id + '"' + checked + ' /> ' + s.name;
                    html += '</label>';
                });
                $list.html(html);
            });
        });
    });

    // 年级联动：加载班级
    $(document).on('change', '#editModalBody #editGradeSelect', function() {
        var gradeName = $(this).val();
        var schoolType = $('#editModalBody select[name="SchoolType"]').val();
        if (gradeName && schoolType) {
            triggerEditLoadClasses(schoolType, gradeName, false);
        } else {
            $('#editModalBody #editClassSelect').html('<option value="">-- 请先选择年级 --</option>');
        }
    });

    function triggerEditLoadClasses(schoolType, gradeName, force) {
        var $sel = $('#editModalBody #editClassSelect');
        var currentClassName = $sel.data('current') || '';
        $sel.html('<option value="">加载中...</option>');
        $.get('@Url.Action("GetClassesByGrade", "Teacher")', { schoolType: schoolType, gradeName: gradeName }, function(data) {
            var html = '<option value="">-- 请选择班级 --</option>';
            data.forEach(function(c) {
                var sel = (c.name === currentClassName) ? ' selected' : '';
                html += '<option value="' + c.name + '"' + sel + '>' + c.name + '</option>';
            });
            $sel.html(html);
        });
    }

    // 页面加载时初始化角色显示和年级班级
    $(function() {
        syncEditModalRoles();
    });

    // 主编辑页面：年级 → 班级联动
    $(document).on('change', '#editGradeSelect', function() {
        var gradeName = $(this).val();
        var schoolType = $('select[name="SchoolType"]').val();
        if (gradeName && schoolType) {
            var $sel = $('#editClassSelect');
            var cur = $sel.data('current') || '';
            $sel.html('<option value="">加载中...</option>');
            $.get('@Url.Action("GetClassesByGrade", "Teacher")', { schoolType: schoolType, gradeName: gradeName }, function(data) {
                var html = '<option value="">-- 请选择班级 --</option>';
                data.forEach(function(c) {
                    var sel = (c.name === cur) ? ' selected' : '';
                    html += '<option value="' + c.name + '"' + sel + '>' + c.name + '</option>';
                });
                $sel.html(html);
            });
        } else {
            $('#editClassSelect').html('<option value="">-- 请先选择年级 --</option>');
        }
    });

    // 主编辑页面：加载时自动选中班级
    $(function() {
        setTimeout(function() {
            var curClass = '@Model.ClassName';
            if (curClass) {
                $('#editClassSelect').data('current', curClass);
                $('#editGradeSelect').trigger('change');
            }
        }, 200);
    });

    // 提交表单时，将所选科目ID写入隐藏字段
    $(document).on('submit', '#editModalBody form', function() {
        var ids = $('#editModalBody .edit-subject-cb:checked').map(function() { return $(this).val(); }).get();
        $('#editModalBody input[name="subjectIds"]').remove();
        ids.forEach(function(id) {
            $('<input>').attr({ type: 'hidden', name: 'subjectIds', value: id }).appendTo('#editModalBody form');
        });
    });
</script>
