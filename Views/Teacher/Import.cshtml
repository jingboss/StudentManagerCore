@{
    ViewData["Title"] = "导入教职工";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-upload me-2"></i>批量导入教职工</h5>
        </div>
        <div class="card-body">
            <form method="post" enctype="multipart/form-data" asp-action="Import">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">选择CSV文件</label>
                    <input type="file" name="file" class="form-control" accept=".csv" required />
                </div>

                <div class="mb-3">
                    <p class="text-muted small mb-1">CSV格式要求（第一行为标题行，将被跳过）：</p>
                    <code>用户名,密码,姓名,手机号,年级,班级,职务</code>
                    <p class="text-muted small mt-1">示例：</p>
                    <code>zhangsan,123456,张三,13800138000,小学2026级,1班,班主任</code>
                    <p class="text-muted small mt-2">提示：建议使用 Excel 导入模板功能（支持更多字段）</p>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-upload me-1"></i>导入
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">
                    <i class="bi bi-x-lg me-1"></i>取消
                </a>
            </form>
        </div>
    </div>
</div>
