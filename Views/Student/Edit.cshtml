@model StudentManagerCore.Models.Student
@{
    ViewData["Title"] = "编辑学生";
    var editRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var isAdmin = editRole == "管理员";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>编辑学生</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> 返回列表
    </a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Edit" id="editStudentForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="StudentID" />
            <input type="hidden" id="studentGradeLevelId" value="@(ViewBag.StudentGradeLevelId?.ToString() ?? "")" />

            <div class="text-danger mb-3" asp-validation-summary="All"></div>

            <h5 class="text-primary border-bottom pb-2 mb-3"><i class="bi bi-person me-1"></i>基本信息</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">学号 <span class="text-danger">*</span></label>
                    @if (isAdmin)
                    {
                        <input asp-for="StudentNo" class="form-control" maxlength="8" title="请输入8位学号" />
                    }
                    else
                    {
                        <input asp-for="StudentNo" class="form-control" readonly />
                    }
                    <span asp-validation-for="StudentNo" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">学生姓名 <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">性别</label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">请选择</option>
                        <option value="男">男</option>
                        <option value="女">女</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">民族</label>
                    <select asp-for="Nation" class="form-select">
                        <option value="">请选择</option>
                        <option value="汉族">汉族</option>
                        <option value="蒙古族">蒙古族</option>
                        <option value="回族">回族</option>
                        <option value="藏族">藏族</option>
                        <option value="维吾尔族">维吾尔族</option>
                        <option value="苗族">苗族</option>
                        <option value="彝族">彝族</option>
                        <option value="壮族">壮族</option>
                        <option value="布依族">布依族</option>
                        <option value="朝鲜族">朝鲜族</option>
                        <option value="满族">满族</option>
                        <option value="侗族">侗族</option>
                        <option value="瑶族">瑶族</option>
                        <option value="白族">白族</option>
                        <option value="土家族">土家族</option>
                        <option value="哈尼族">哈尼族</option>
                        <option value="其他">其他</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">身份证号</label>
                    <input asp-for="IDCardNumber" class="form-control" maxlength="18" oninput="this.value = this.value.toUpperCase()" />
                    <span asp-validation-for="IDCardNumber" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label class="form-label">年级 <span class="text-danger">*</span></label>
                    <select asp-for="Grade" class="form-select" id="gradeSelect">
                        <option value="">-- 请选择年级 --</option>
                        @if (ViewBag.Grades != null)
                        {
                            foreach (var g in (ViewBag.Grades as IEnumerable<StudentManagerCore.Models.GradeLevel>)!)
                            {
                                <option value="@g.CurrentGradeName" data-gradeid="@g.GradeLevelID">@g.CurrentGradeName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">班级 <span class="text-danger">*</span></label>
                    <select asp-for="ClassName" class="form-select" id="classSelect" data-current="@Model.ClassName">
                        <option value="">-- 请先选择年级 --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">就读状态</label>
                    <select asp-for="Status" class="form-select">
                        <option value="在读">在读</option>
                        <option value="毕业">毕业</option>
                        <option value="休学">休学</option>
                        <option value="转学">转学</option>
                    </select>
                </div>
            </div>

            <h5 class="text-primary border-bottom pb-2 mt-4 mb-3"><i class="bi bi-house-door me-1"></i>户籍信息</h5>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">户口性质</label>
                    <select asp-for="HouseholdType" class="form-select" onchange="applyHouseholdRule()">
                        <option value="">请选择</option>
                        <option value="农业户口">农业户口</option>
                        <option value="非农业户口">非农业户口</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">户口所在地（省市）</label>
                    <input asp-for="HouseholdCity" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">户口簿中首页家庭地址</label>
                    <input asp-for="HouseholdAddress" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">是否非本地户籍</label>
                    <select asp-for="IsNonLocalHousehold" class="form-select" onchange="applyHouseholdRule()">
                        <option value="">请选择</option>
                        <option value="本地户籍">本地户籍</option>
                        <option value="省内非本地户籍">省内非本地户籍</option>
                        <option value="省外非本地户籍">省外非本地户籍</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">是否随迁子女</label>
                    <select asp-for="IsMigrantChild" class="form-select">
                        <option value="">请选择</option>
                        <option value="否">否</option>
                        <option value="省内其他市迁入">省内其他市迁入</option>
                        <option value="省外迁入">省外迁入</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">是否进城务工人员子女</label>
                    <select asp-for="IsMigrantWorkerChild" class="form-select">
                        <option value="">请选择</option>
                        <option value="否">否</option>
                        <option value="省内其他市迁入">省内其他市迁入</option>
                        <option value="省外迁入">省外迁入</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">现居住家庭地址</label>
                    <input asp-for="CurrentResidence" class="form-control" />
                </div>
            </div>

            <h5 class="text-primary border-bottom pb-2 mt-4 mb-3"><i class="bi bi-telephone me-1"></i>家长信息</h5>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">父亲姓名</label>
                    <input asp-for="FatherName" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">父亲联系电话</label>
                    <input asp-for="FatherPhone" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">母亲姓名</label>
                    <input asp-for="MotherName" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">母亲联系电话</label>
                    <input asp-for="MotherPhone" class="form-control" />
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-12">
                    <label class="form-label">备注</label>
                    <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i> 保存修改
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">取消</a>
            </div>

            <input type="hidden" id="allClassesData" value='@Html.Raw(ViewBag.AllClasses != null ? Json.Serialize(ViewBag.AllClasses) : "[]")' />
        </form>
    </div>
</div>

<script>
var householdRules = {
    '非农业户口': {
        '本地户籍':      { migrant: '否', worker: '否' },
        '省内非本地户籍': { migrant: '省内其他市迁入', worker: '否' },
        '省外非本地户籍': { migrant: '省外迁入', worker: '否' }
    },
    '农业户口': {
        '省内非本地户籍': { migrant: '省内其他市迁入', worker: '省内其他市迁入' },
        '省外非本地户籍': { migrant: '省外迁入', worker: '省外迁入' }
    }
};
function applyHouseholdRule() {
    var sel1 = document.getElementById('HouseholdType');
    var sel2 = document.getElementById('IsNonLocalHousehold');
    if (!sel1 || !sel2) return;
    var t = sel1.value, n = sel2.value;
    if (t && n && householdRules[t] && householdRules[t][n]) {
        var r = householdRules[t][n];
        var mc = document.getElementById('IsMigrantChild');
        var mw = document.getElementById('IsMigrantWorkerChild');
        if (mc) mc.value = r.migrant;
        if (mw) mw.value = r.worker;
    }
}
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(function () {
            // 按 GradeLevelID 预选年级（不再依赖静态 Grade 名称）
            var studentGradeLevelId = @(ViewBag.StudentGradeLevelId?.ToString() ?? "null");
            if (studentGradeLevelId) {
                $('#gradeSelect option').each(function() {
                    if ($(this).data('gradeid') == studentGradeLevelId) {
                        $(this).prop('selected', true);
                        return false;
                    }
                });
            }

            var el = $('#allClassesData');
            if (el.length && el.val()) {
                var allClasses = JSON.parse(el.val());
                $('#gradeSelect').off('change').on('change', function () {
                    var gradeId = $(this).find('option:selected').data('gradeid');
                    var cur = '@Model.ClassName';
                    var sel = $('#classSelect').empty();
                    if (!gradeId) { sel.append('<option value="">-- 请先选择年级 --</option>'); return; }
                    var f = allClasses.filter(function (c) { return c.gradeLevelID === gradeId; });
                    if (f.length > 0) {
                        sel.append('<option value="">-- 请选择班级 --</option>');
                        $.each(f, function (i, c) {
                            var cn = c.className || '';
                            sel.append('<option value="' + cn + '"' + (cn === cur ? ' selected' : '') + '>' + cn + '</option>');
                        });
                    } else { sel.append('<option value="">-- 暂无班级 --</option>'); }
                });
                if ($('#gradeSelect').val()) $('#gradeSelect').trigger('change');
            }
        });
    </script>
}
