            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="btnImportSubmit">
                    <i class="bi bi-cloud-upload me-1"></i>开始导入
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 批量转班 Modal -->
<div class="modal fade" id="batchTransferModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-arrows-move me-2"></i>批量转班</h5>
