@section Scripts {
    <!-- 右键菜单 -->
    <div id="contextMenu" class="dropdown-menu shadow" style="position:fixed;display:none;z-index:9999;min-width:140px;">
        @if (isNormalView)
        {
            <a class="dropdown-item" href="#" id="ctxView"><i class="bi bi-eye me-2"></i>查看</a>
            @* 管理年级 tab 只能查看，不能编辑删除 *@
            if (canEdit && activeTab != "grade")
            {
                <a class="dropdown-item" href="#" id="ctxEdit"><i class="bi bi-pencil-square me-2"></i>编辑</a>
            }
            if (canDelete && activeTab != "grade")
            {
                <div class="dropdown-divider"></div>
                <a class="dropdown-item text-primary" href="#" id="ctxTransfer"><i class="bi bi-box-arrow-up-right me-2"></i>转出</a>
            }
        }
        @if (isDeletedView)
        {
            <a class="dropdown-item" href="#" id="ctxView"><i class="bi bi-eye me-2"></i>查看</a>
            <div class="dropdown-divider"></div>
            <a class="dropdown-item text-success" href="#" id="ctxRestore"><i class="bi bi-arrow-repeat me-2"></i>恢复</a>
            if (isAdmin)
            {
                <div class="dropdown-divider"></div>
                <a class="dropdown-item text-danger" href="#" id="ctxHardDelete"><i class="bi bi-trash3 me-2"></i>彻底删除</a>
            }
        }
    </div>

    <!-- 编辑Modal -->
    <div class="modal fade" id="editModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>编辑学生</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="editModalBody">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">加载中...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 添加学生Modal -->
    <div class="modal fade" id="addModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-plus-fill me-2"></i>添加学生</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="addModalBody">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">加载中...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 查看Modal -->
    <div class="modal fade" id="viewModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-eye me-2"></i>学生详情</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="viewModalBody">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-muted">加载中...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 转出对话框 -->
    <div class="modal fade" id="transferModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-box-arrow-up-right me-2"></i>学生转出</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="transferStudentId" />
                    <div class="mb-3">
                        <label class="form-label">学生姓名</label>
                        <input type="text" class="form-control" id="transferName" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">性别</label>
                        <input type="text" class="form-control" id="transferGender" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">转出时间</label>
                        <input type="date" class="form-control" id="transferTime" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="button" class="btn btn-primary" id="btnConfirmTransfer"><i class="bi bi-check-lg me-1"></i>确定转出</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        var contextStudentId = null;
        // 查看详情中的掩码切换
        function toggleMask(btn) {
            var span = btn.closest("td").querySelector(".masked-value");
            if (!span) return;
            var icon = btn.querySelector("i");
            if (span.dataset.fullVisible === "1") {
                span.textContent = span.dataset.masked;
                icon.className = "bi bi-eye";
                span.dataset.fullVisible = "0";
            } else {
                span.dataset.masked = span.textContent;
                span.textContent = span.dataset.full;
                icon.className = "bi bi-eye-slash";
                span.dataset.fullVisible = "1";
            }
        }

$(document).on('contextmenu', '.context-row', function(e) {
            e.preventDefault();
            contextStudentId = $(this).data('id');
            var menu = $('#contextMenu');
            var top = e.clientY, left = e.clientX;
            menu.css({ left: left + 'px', top: top + 'px' }).show();
            // 如果菜单超出底部，向上弹出
            var menuH = menu.outerHeight();
            var winH = $(window).height();
            if (top + menuH > winH) {
                menu.css('top', Math.max(0, top - menuH) + 'px');
            }
            // 如果菜单超出右侧，向左弹出
            var menuW = menu.outerWidth();
            var winW = $(window).width();
            if (left + menuW > winW) {
                menu.css('left', Math.max(0, left - menuW) + 'px');
            }
        });

        $(document).click(function() { $('#contextMenu').hide(); });

        $('#ctxEdit').click(function(e) {
            e.preventDefault();
            $('#contextMenu').hide();
            if (!contextStudentId) return;
            $('#editModalBody').html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">加载中...</p></div>');
            $('#editModal').modal('show');
            $.get('/Student/Edit/' + contextStudentId, function(html) {
                var formHtml = $(html).find('#editStudentForm').first();
                if (formHtml.length === 0) { formHtml = $('<div>').html(html).find('#editStudentForm'); }
                if (formHtml.length > 0) {
                    formHtml.find('button[type="submit"]').prop('disabled', false).text('保存');
                    $('#editModalBody').html(formHtml);
                    // 初始化级联下拉（班级管理数据在 hidden input 中）
                    initClassCascade($('#editModalBody'));
                    if ($('#editModalBody input[name="__RequestVerificationToken"]').length === 0) {
                        var token = $('[name="__RequestVerificationToken"]').first().val();
                        if (token) { $('#editModalBody form').prepend('<input name="__RequestVerificationToken" type="hidden" value="' + token + '" />'); }
                    }
                    $('#editModalBody form').on('submit', function(e) {
                        e.preventDefault();
                        var form = $(this);
                        var btn = form.find('button[type="submit"]');
                        btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>保存中...');
                        $.post(form.attr('action'), form.serialize())
                            .done(function(r) {
                                if (r.success) { $('#editModal').modal('hide'); location.reload(); }
                                else { alert(r.message || '保存失败'); btn.prop('disabled', false).text('保存'); }
                            }).fail(function() { alert('网络错误，请重试'); btn.prop('disabled', false).text('保存'); });
                    });
                } else { $('#editModalBody').html('<div class="alert alert-danger">无法加载编辑表单</div>'); }
            }).fail(function() { $('#editModalBody').html('<div class="alert alert-danger">加载失败</div>'); });
        });

        $('#ctxView').click(function(e) {
            e.preventDefault();
            $('#contextMenu').hide();
            if (!contextStudentId) return;
            $('#viewModalBody').html('<div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div><p class="mt-2 text-muted">加载中...</p></div>');
            $('#viewModal').modal('show');
            $.get('/Student/Details/' + contextStudentId, function(html) {
                var $html = $('<div>').html(html);
                var content = $html.find('main').html() || $html.find('.container').html() || $html.find('.card').html() || html;
                $('#viewModalBody').html(content);
            }).fail(function() { $('#viewModalBody').html('<div class="alert alert-danger">加载失败</div>'); });
        });

        $('#ctxTransfer').click(function(e) {
            e.preventDefault(); $('#contextMenu').hide();
            if (!contextStudentId) return;
            var row = $('.context-row[data-id="' + contextStudentId + '"]');
            $('#transferStudentId').val(contextStudentId);
            $('#transferName').val(row.data('name'));
            $('#transferGender').val(row.data('gender'));
            $('#transferTime').val(new Date().toISOString().slice(0, 10));
            new bootstrap.Modal(document.getElementById('transferModal')).show();
        });

        $('#btnConfirmTransfer').click(function() {
            var id = $('#transferStudentId').val();
            var time = $('#transferTime').val();
            if (!id) return;
            if (!time) { alert('请选择转出时间'); return; }
            $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>处理中...');
            $.post('@Url.Action("Delete")', {
                id: id,
                transferOutTime: time,
                __RequestVerificationToken: $('[name="__RequestVerificationToken"]').first().val()
            }).done(function(res) {
                if (res.success) { location.reload(); }
                else { alert(res.message); }
            }).fail(function() {
                alert('操作失败');
            }).always(function() {
                $('#btnConfirmTransfer').prop('disabled', false).html('<i class="bi bi-check-lg me-1"></i>确定转出');
            });
        });

        // 行内按钮操作
        window.editStudent = function(id) {
            contextStudentId = id;
            $('#ctxEdit').trigger('click');
        };

        window.deleteStudent = function(id) {
            contextStudentId = id;
            $('#ctxTransfer').trigger('click');
        };

        $('#ctxRestore').click(function(e) {
            e.preventDefault(); $('#contextMenu').hide();
            if (!contextStudentId) return;
            showConfirm('确认恢复该学生？', function() {
                $.post('@Url.Action("Restore")', { id: contextStudentId, __RequestVerificationToken: $('[name="__RequestVerificationToken"]').first().val() })
                    .done(function(res) { if (res.success) location.reload(); else alert(res.message); });
            });
        });

        $('#ctxHardDelete').click(function(e) {
            e.preventDefault(); $('#contextMenu').hide();
            if (!contextStudentId) return;
            var code = prompt('请输入安全码以确认彻底删除：');
            if (!code) return;
            $.post('@Url.Action("HardDelete")', { id: contextStudentId, securityCode: code, __RequestVerificationToken: $('[name="__RequestVerificationToken"]').first().val() })
                .done(function(res) { if (res.success) location.reload(); else alert(res.message); });
        });

        // 级联下拉：年级 → 班级（供右键编辑弹窗使用）
        function initClassCascade(container) {
            var allClassesData = container.find('#allClassesData').val();
            if (!allClassesData) return;
            var allClasses;
            try { allClasses = JSON.parse(allClassesData); } catch(e) { return; }
            var gradeSelect = container.find('#gradeSelect');
            var classSelect = container.find('#classSelect');
            if (!gradeSelect.length || !classSelect.length) return;

            gradeSelect.off('change').on('change', function () {
                var gradeId = $(this).find('option:selected').data('gradeid');
                classSelect.empty();
                if (!gradeId) { classSelect.append('<option value="">-- 请先选择年级 --</option>'); return; }
                var f = allClasses.filter(function (c) { return c.gradeLevelID === gradeId; });
                if (f.length > 0) {
                    classSelect.append('<option value="">-- 请选择班级 --</option>');
                    $.each(f, function (i, c) {
                        var cn = c.className || '';
                        var displayName = (c.gradeDisplayName || '') + cn;
                        var cur = classSelect.data('current') || '';
                        var s = (cn === cur) ? ' selected' : '';
                        classSelect.append('<option value="' + cn + '"' + s + '>' + displayName + '</option>');
                    });
                } else { classSelect.append('<option value="">-- 暂无班级 --</option>'); }
            });

            // 按 GradeLevelID 预选年级（不再依赖静态 Grade 名称）
            var studentGradeLevelId = container.find('#studentGradeLevelId').val();
            if (studentGradeLevelId) {
                gradeSelect.find('option').each(function() {
                    if ($(this).data('gradeid') == studentGradeLevelId) {
                        $(this).prop('selected', true);
                        return false;
                    }
                });
            }

            // 如果有选中的年级，触发加载
            if (gradeSelect.val()) gradeSelect.trigger('change');
        }

        // 添加学生按钮 - 弹出模态框
        $('#btnAddStudent').on('click', function () {
            var modal = new bootstrap.Modal(document.getElementById('addModal'));
            modal.show();

            $.get('/Student/Add')
                .done(function (html) {
                    var form = $(html).find('#addStudentForm');
                    if (form.length === 0) {
                        $('#addModalBody').html('<div class="alert alert-danger">加载失败，请刷新页面重试</div>');
                        return;
                    }
                    $('#addModalBody').html(form);

                    // 初始化级联下拉框
                    initClassCascade($('#addModalBody'));

                    // 替换提交为AJAX
                    $('#addModalBody form').off('submit').on('submit', function (e) {
                        e.preventDefault();
                        var btn = $(this).find('button[type="submit"]');
                        btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> 提交中...');

                        $.post('/Student/Add', $(this).serialize())
                            .done(function (res) {
                                if (res.success) {
                                    modal.hide();
                                    location.reload();
                                } else {
                                    alert(res.message || '提交失败');
                                    btn.prop('disabled', false).text('保存');
                                }
                            })
                            .fail(function (xhr) {
                                var msg = '提交失败';
                                try { msg = JSON.parse(xhr.responseText).message || msg; } catch (ex) { }
                                alert(msg);
                                btn.prop('disabled', false).text('保存');
                            });
                    });
                })
                .fail(function () {
                    $('#addModalBody').html('<div class="alert alert-danger">加载失败，请刷新页面重试</div>');
                });
        });

        // 导入按钮
        $('#btnImport').on('click', function () {
            $('#importFile').val('');
            $('#importResult').addClass('d-none').html('');
            $('#importProgress').addClass('d-none');
            var modal = new bootstrap.Modal(document.getElementById('importModal'));
            modal.show();
        });

        $('#btnImportSubmit').on('click', function () {
            var file = $('#importFile')[0].files[0];
            if (!file) { alert('请选择文件'); return; }

            var btn = $(this);
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> 导入中...');
            $('#importProgress').removeClass('d-none');
            $('#importResult').addClass('d-none');

            var formData = new FormData();
            formData.append('file', file);
            formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

            $.ajax({
                url: '/Student/Import',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false
            }).done(function (res) {
                $('#importProgress').addClass('d-none');
                var cls = res.success ? 'alert-success' : 'alert-danger';
                $('#importResult').removeClass('d-none').addClass('alert ' + cls).html(res.message);
                if (res.success && res.imported > 0) {
                    setTimeout(function () { location.reload(); }, 1500);
                }
            }).fail(function (xhr) {
                $('#importProgress').addClass('d-none');
                var msg = '导入失败';
                try { msg = JSON.parse(xhr.responseText).message || msg; } catch (ex) { }
                $('#importResult').removeClass('d-none').addClass('alert alert-danger').html(msg);
            }).always(function () {
                btn.prop('disabled', false).html('<i class="bi bi-cloud-upload me-1"></i>开始导入');
            });
        });

        // ========== 批量操作：全选 / 取消全选 ==========
        $(document).on('change', '#selectAll', function () {
            $('.student-checkbox').prop('checked', $(this).is(':checked'));
            updateBatchToolbar();
        });

        $(document).on('change', '.student-checkbox', function () {
            updateBatchToolbar();
            var allChecked = $('.student-checkbox:checked').length === $('.student-checkbox').length;
            $('#selectAll').prop('checked', allChecked);
        });

        function getSelectedIds() {
            var ids = [];
            $('.student-checkbox:checked').each(function () { ids.push($(this).val()); });
            return ids;
        }

        function updateBatchToolbar() {
            var count = $('.student-checkbox:checked').length;
            $('#selectedCount').text('已选择 ' + count + ' 人');
            $('#batchToolbar').toggleClass('d-none', count === 0);
        }

        // ========== 批量毕业 ==========
        $('#btnBatchGraduate').on('click', function () {
            var ids = getSelectedIds();
            if (ids.length === 0) { alert('请先选择学生'); return; }
            showConfirm('确定将所选 ' + ids.length + ' 名学生标记为已毕业？', function () {
                $.post('@Url.Action("BatchGraduate")', {
                    ids: ids,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                }).done(function (res) {
                    if (res.success) { location.reload(); } else { alert(res.message); }
                }).fail(function () { alert('操作失败'); });
            });
        });

        // ========== 批量删除 ==========
        $('#btnBatchDelete').on('click', function () {
            var ids = getSelectedIds();
            if (ids.length === 0) { alert('请先选择学生'); return; }
            showConfirm('确定将所选 ' + ids.length + ' 名学生移入已删除？', function () {
                $.post('@Url.Action("BatchDelete")', {
                    ids: ids,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                }).done(function (res) {
                    if (res.success) { location.reload(); } else { alert(res.message); }
                }).fail(function () { alert('操作失败'); });
            });
        });

        // ========== 批量恢复 ==========
        $('#btnBatchRestore').on('click', function () {
            var ids = getSelectedIds();
            if (ids.length === 0) { alert('请先选择学生'); return; }
            showConfirm('确定恢复所选 ' + ids.length + ' 名学生在读？', function () {
                $.post('@Url.Action("BatchRestore")', {
                    ids: ids,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                }).done(function (res) {
                    if (res.success) { location.reload(); } else { alert(res.message); }
                }).fail(function () { alert('操作失败'); });
            });
        });

        // ========== 批量转班：弹出 Modal 选择目标班级 ==========
        $('#btnBatchTransfer').on('click', function () {
            var ids = getSelectedIds();
            if (ids.length === 0) { alert('请先选择学生'); return; }
            $('#batchTransferIds').val(JSON.stringify(ids));
            $('#batchTransferCount').text(ids.length);
            new bootstrap.Modal(document.getElementById('batchTransferModal')).show();
        });

        // 批量转班级联下拉：年级 → 班级（AJAX 加载）
        $('#batchTargetGrade').on('change', function () {
            var grade = $(this).val();
            var classSelect = $('#batchTargetClass');
            classSelect.empty().append('<option value="">-- 加载中... --</option>').prop('disabled', true);
            if (!grade) {
                classSelect.empty().append('<option value="">-- 请先选择年级 --</option>').prop('disabled', true);
                return;
            }
            $.get('@Url.Action("GetClassesByGradeName")', { gradeName: grade })
                .done(function (classes) {
                    classSelect.empty().append('<option value="">-- 请选择班级 --</option>');
                    $.each(classes, function (i, c) {
                        classSelect.append('<option value="' + $('<div>').text(c.className).html() + '">' + $('<div>').text(c.className).html() + '</option>');
                    });
                    classSelect.prop('disabled', false);
                }).fail(function () {
                    classSelect.empty().append('<option value="">-- 加载失败 --</option>');
                });
        });

        $('#btnBatchTransferSubmit').on('click', function () {
            var targetGrade = $('#batchTargetGrade').val();
            var targetClass = $('#batchTargetClass').val();
            if (!targetGrade || !targetClass) { alert('请选择目标年级和班级'); return; }
            var ids = JSON.parse($('#batchTransferIds').val() || '[]');
            if (ids.length === 0) { alert('没有待转班的学生'); return; }

            $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>转班中...');
            $.post('@Url.Action("BatchTransfer")', {
                ids: ids,
                targetGrade: targetGrade,
                targetClass: targetClass,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            }).done(function (res) {
                if (res.success) { location.reload(); } else { alert(res.message); }
            }).fail(function () { alert('操作失败'); }).always(function () {
                $('#btnBatchTransferSubmit').prop('disabled', false).html('<i class="bi bi-arrows-move me-1"></i>确认转班');
            });
        });

        // ========== AI报告查看（在详情弹窗中使用） ==========
        function btnViewAiReport(studentId) {
            var examId = document.getElementById('aiReportExamSelect').value;
            if (!examId) { alert('请选择考试'); return; }
            document.getElementById('aiReportEmpty').style.display = 'none';
            document.getElementById('aiReportContent').style.display = 'none';
            document.getElementById('aiReportBody').innerHTML = '<div class="text-center py-3"><div class="spinner-border text-success" role="status"></div><div class="mt-2 small text-muted">加载中...</div></div>';
            document.getElementById('aiReportContent').style.display = 'block';
            document.getElementById('aiReportHeader').textContent = '';
            var sp = new URLSearchParams();
            sp.append('examScheduleId', examId);
            sp.append('studentId', studentId);
            fetch('@Url.Action("GetStudentAiReport", "Score")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: sp
            }).then(function (r) { return r.json(); }).then(function (res) {
                if (!res.success || !res.exists) {
                    document.getElementById('aiReportContent').style.display = 'none';
                    var msg = res.message || '暂无AI分析报告';
                    if (res.debug) {
                        msg += ' | 考试ID=' + res.debug.receivedExamScheduleId + ', 学生ID=' + res.debug.receivedStudentId;
                        msg += ' | 该学生有 ' + res.debug.cachedReportCount + ' 份缓存: ';
                        if (res.debug.cachedExams && res.debug.cachedExams.length > 0) {
                            for (var i = 0; i < res.debug.cachedExams.length; i++) {
                                msg += res.debug.cachedExams[i].examName + '(ID=' + res.debug.cachedExams[i].examId + ') ';
                            }
                        }
                    }
                    document.getElementById('aiReportEmpty').textContent = msg;
                    document.getElementById('aiReportEmpty').style.display = 'block';
                    return;
                }
                document.getElementById('aiReportHeader').textContent = '学生：' + res.studentName + ' | ' + document.getElementById('aiReportExamSelect').options[document.getElementById('aiReportExamSelect').selectedIndex].text + '（' + res.updatedAt + '生成）';
                var html = (res.analysis || '')
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>')
                    .replace(/### (.*?)(?:<br>|$)/g, '<h6 class="mt-3 mb-2 text-primary">$1</h6>')
                    .replace(/## (.*?)(?:<br>|$)/g, '<h5 class="mt-3 mb-2 fw-bold">$1</h5>')
                    .replace(/- (.*?)(?:<br>|$)/g, '<li>$1</li>');
                html = html.replace(/(<li>.*?<\/li>)/g, '<ul class="mb-2">$1</ul>');
                html = html.replace(/<\/ul>\s*<ul class="mb-2">/g, '');
                document.getElementById('aiReportBody').innerHTML = html;
                document.getElementById('aiReportContent').style.display = 'block';
            }).catch(function () {
                document.getElementById('aiReportBody').innerHTML = '<div class="alert alert-danger mb-0">网络错误</div>';
            });
        }
    </script>
}
}
