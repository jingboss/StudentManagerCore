@model List<StudentManagerCore.Models.ExamRoom>
@{
    var schedule = ViewBag.Schedule as StudentManagerCore.Models.ExamSchedule;
    var grade = ViewBag.Grade as string;
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>考场安排 - @schedule?.Name</title>
    <style>
        /* ========== A4 页面设置 ========== */
        @@page {
            size: A4 portrait;
            margin: 10mm 12mm 12mm 12mm;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Microsoft YaHei', 'PingFang SC', 'SimHei', sans-serif;
            font-size: 11pt;
            line-height: 1.6;
            color: #222;
        }

        /* ========== 每班一页 ========== */
        .room-page {
            page-break-after: always;
            display: flex;
            flex-direction: column;
            min-height: 80vh;
        }
        .room-page:last-child {
            page-break-after: avoid;
        }

        /* ========== 页头 ========== */
        .page-header {
            text-align: center;
            border-bottom: 2px solid #222;
            padding-bottom: 6px;
            margin-bottom: 8px;
        }
        .page-header h1 {
            font-size: 14pt;
            font-weight: bold;
            letter-spacing: 4px;
        }
        .page-header .room-name {
            font-size: 13pt;
            font-weight: bold;
            color: #c00;
            margin-top: 2px;
        }
        .page-header .meta {
            font-size: 9pt;
            color: #555;
            margin-top: 3px;
        }
        .page-header .meta span {
            margin: 0 12px;
        }

        /* ========== 座位表 ========== */
        .seat-grid {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .seat-table {
            width: 100%;
            border-collapse: collapse;
            border: 2px solid #222;
            background: #fff;
        }
        .seat-table thead th {
            border: 1px solid #222;
            padding: 3px 6px;
            font-size: 10pt;
            font-weight: bold;
            text-align: center;
            background: #fff;
        }
        .seat-table tbody td {
            border: 1px solid #999;
            padding: 2px 6px;
            font-size: 9.5pt;
            text-align: center;
            vertical-align: middle;
            background: #fff;
        }
        .seat-table .col-seat { width: 8%; font-weight: bold; color: #555; }
        .seat-table .col-name { width: 30%; text-align: left; }
        .seat-table .col-class { width: 22%; text-align: left; color: #555; font-size: 9.5pt; }

        /* ========== 页脚 ========== */
        .page-footer {
            text-align: center;
            font-size: 8pt;
            color: #999;
            border-top: 1px solid #ddd;
            padding-top: 4px;
            margin-top: 6px;
        }

        /* ========== 打印按钮（仅屏幕显示） ========== */
        .no-print { display: block; }
        @@media print {
            .no-print { display: none !important; }
            body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body>

    @{
        var rooms = Model.OrderBy(r => r.RoomName).ToList();
    }

    @for (int ri = 0; ri < rooms.Count; ri++)
    {
        var room = rooms[ri];
        var students = room.Students?.OrderBy(s => s.SeatNumber).ToList() ?? new();
        int total = students.Count;
        int leftCount = (int)Math.Ceiling(total / 2.0);

        <div class="room-page">
            <!-- 页头 -->
            <div class="page-header">
                <h1>@schedule?.Name 考场安排表</h1>
                <div class="room-name">@room.RoomName（@room.SeatCount 人）</div>
                <div class="meta">
                    <span>年级：@grade</span>
                    <span>考试日期：@schedule?.ExamDate.ToString("yyyy-MM-dd")</span>
                    <span>打印时间：@DateTime.Now.ToString("yyyy-MM-dd HH:mm")</span>
                </div>
            </div>

            <!-- 座位表 -->
            <div class="seat-grid">
                <table class="seat-table">
                    <thead>
                        <tr>
                            <th class="col-seat">座位号</th>
                            <th class="col-name">姓名</th>
                            <th class="col-class">班级</th>
                            <th class="col-seat">座位号</th>
                            <th class="col-name">姓名</th>
                            <th class="col-class">班级</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < leftCount; i++)
                        {
                            var left = students[i];
                            var right = (i + leftCount) < total ? students[i + leftCount] : null;
                            <tr>
                                <td class="col-seat">@left.SeatNumber</td>
                                <td class="col-name">@left.Student?.Name</td>
                                <td class="col-class">@left.Student?.ClassName</td>
                                @if (right != null)
                                {
                                    <td class="col-seat">@right.SeatNumber</td>
                                    <td class="col-name">@right.Student?.Name</td>
                                    <td class="col-class">@right.Student?.ClassName</td>
                                }
                                else
                                {
                                    <td class="col-seat"></td>
                                    <td class="col-name"></td>
                                    <td class="col-class"></td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- 页脚 -->
            <div class="page-footer">
                本表为座位编排依据，请监考教师按座位号安排考生就座。
            </div>
        </div>
    }

    <div style="text-align:center;margin-top:20px;">
        <button class="no-print" onclick="window.print()" style="padding:10px 40px;font-size:16px;cursor:pointer;">
            🖨️ 打印
        </button>
    </div>

</body>
</html>
