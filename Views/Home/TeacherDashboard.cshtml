@using StudentManagerCore.Models
@{
    ViewData["Title"] = "教师工作台";
    var myClass = ViewBag.MyClass as ClassInfo;
    var studentCount = ViewBag.StudentCount as int? ?? 0;
    var teacherName = ViewBag.TeacherName as string ?? "";
    var roleDisplay = ViewBag.RoleDisplay as string ?? "";
    var maleCount = ViewBag.MaleCount as int? ?? 0;
    var femaleCount = ViewBag.FemaleCount as int? ?? 0;
    var activeCount = ViewBag.ActiveCount as int? ?? 0;
    var teachingSubjects = ViewBag.TeachingSubjects as List<Subject> ?? new List<Subject>();
    var teachingClasses = ViewBag.TeachingClasses as List<ClassInfo> ?? new List<ClassInfo>();
    var unreadAnnCount = ViewBag.UnreadAnnCount as int? ?? 0;
    var pendingExams = ViewBag.PendingExams as List<ExamSchedule> ?? new List<ExamSchedule>();
    var pendingRepairCount = ViewBag.PendingRepairCount as int? ?? 0;
}

@Html.AntiForgeryToken()

<div class="container-fluid py-4">
    <!-- 欢迎横幅 -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-primary text-white">
                <div class="card-body text-center py-4">
                    <h3 class="mb-0"><i class="bi bi-person-badge me-2"></i>欢迎，@teacherName</h3>
                    <p class="mb-0 mt-2">
                        <span class="badge bg-light text-dark fs-6 me-2">
                            <i class="bi bi-person-check me-1"></i>@roleDisplay
                        </span>
                        @foreach (var subj in teachingSubjects)
                        {
                            <span class="badge bg-warning text-dark fs-6 me-1">
                                <i class="bi bi-book me-1"></i>@subj.Name
                            </span>
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- 待办事项 -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-warning h-100">
                <div class="card-header bg-warning bg-opacity-10">
                    <i class="bi bi-exclamation-triangle me-2"></i>待办事项
                </div>
                <div class="card-body">
                    @if (pendingExams.Count == 0 && unreadAnnCount == 0 && pendingRepairCount == 0)
                    {
                        <p class="text-muted mb-0"><i class="bi bi-check-circle text-success me-1"></i>暂无待办事项</p>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-0">
                            @foreach (var pe in pendingExams)
                            {
                                <li class="mb-2">
                                    <span class="badge bg-warning me-1">录入</span>
                                    <span>@pe.Name（考试日期 @pe.ExamDate.ToString("MM月dd日")）</span>
                                </li>
                            }
                            @if (unreadAnnCount > 0)
                            {
                                <li class="mb-2">
                                    <span class="badge bg-info me-1">公告</span>
                                    <span>您有 <strong>@unreadAnnCount</strong> 条未读公告</span>
                                </li>
                            }
                            @if (pendingRepairCount > 0)
                            {
                                <li>
                                    <span class="badge bg-danger me-1">维修</span>
                                    <span>有 <strong>@pendingRepairCount</strong> 条维修申请待处理</span>
                                    <a asp-controller="Logistics" asp-action="Index" class="btn btn-sm btn-outline-danger ms-2">去处理</a>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-info h-100">
                <div class="card-header bg-info bg-opacity-10">
                    <i class="bi bi-book me-2"></i>教学信息
                </div>
                <div class="card-body">
                    <p class="mb-1">
                        <i class="bi bi-journal-text me-1 text-info"></i>
                        任教科目：<strong>@string.Join("、", teachingSubjects.Select(s => s.Name))</strong>
                        （<em>@teachingSubjects.Count 科</em>）
                    </p>
                    @if (teachingClasses.Count > 0)
                    {
                        <p class="mb-0">
                            <i class="bi bi-people me-1 text-info"></i>
                            任教班级：
                            @foreach (var tc in teachingClasses)
                            {
                                <span class="badge bg-info me-1">@tc.GradeLevel?.DisplayName@tc.ClassName</span>
                            }
                        </p>
                    }
                    @if (myClass != null)
                    {
                        <p class="mb-0 mt-1">
                            <i class="bi bi-house-door me-1 text-info"></i>
                            班主任班级：<strong>@myClass.GradeLevel?.DisplayName@myClass.ClassName</strong>
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (myClass != null)
    {
        <!-- 统计卡片 -->
        <div class="row g-3 mb-4">
            <div class="col-md-3 col-6">
                <div class="card bg-primary text-white h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-people-fill fs-2"></i>
                        <h2 class="mt-1 mb-0">@studentCount</h2>
                        <p class="mb-0 small">班级总人数</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card bg-info text-white h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-check-circle-fill fs-2"></i>
                        <h2 class="mt-1 mb-0">@activeCount</h2>
                        <p class="mb-0 small">在读人数</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card" style="background:#0d6efd;color:white;border:none;">
                    <div class="card-body text-center">
                        <i class="bi bi-gender-male fs-2"></i>
                        <h2 class="mt-1 mb-0">@maleCount</h2>
                        <p class="mb-0 small">男生</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="card" style="background:#dc3545;color:white;border:none;">
                    <div class="card-body text-center">
                        <i class="bi bi-gender-female fs-2"></i>
                        <h2 class="mt-1 mb-0">@femaleCount</h2>
                        <p class="mb-0 small">女生</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- 班级信息 + 性别比例 -->
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card border-primary h-100">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-people-fill text-primary" style="font-size:2.5rem;"></i>
                        <h4 class="mt-3">@myClass.GradeLevel?.DisplayName@myClass.ClassName</h4>
                        <p class="text-muted mb-0">您负责的班级</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white py-2">
                        <small class="fw-bold"><i class="bi bi-pie-chart-fill me-1 text-success"></i>性别比例</small>
                    </div>
                    <div class="card-body d-flex align-items-center justify-content-center" style="min-height:160px;">
                        <canvas id="genderChart" height="140"></canvas>
                    </div>
                </div>
            </div>
        </div>

        
    }

    <!-- 快捷操作 -->
    <div class="card">
        <div class="card-header">
            <i class="bi bi-lightning me-2"></i>快捷操作
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3 col-6">
                    <a asp-controller="Student" asp-action="Index" asp-route-tab="teaching"
                       class="btn btn-outline-primary w-100 py-3">
                        <i class="bi bi-people me-2"></i>所教班级成绩
                    </a>
                </div>
                <div class="col-md-3 col-6">

                </div>
                @if (myClass != null)
                {
                    <div class="col-md-3 col-6">
                        <a asp-controller="Student" asp-action="Index"
                           class="btn btn-outline-success w-100 py-3">
                            <i class="bi bi-person-lines-fill me-2"></i>查看本班学生
                        </a>
                    </div>
                    <div class="col-md-3 col-6">
                        <a asp-controller="Student" asp-action="Add"
                           class="btn btn-outline-info w-100 py-3">
                            <i class="bi bi-person-plus me-2"></i>添加学生
                        </a>
                    </div>
                }
                @if (pendingExams.Count > 0)
                {
                    <!-- 待录入提示已移至上面待办事项 -->
                }
            </div>
        </div>
    </div>

    @if (myClass == null && teachingSubjects.Count == 0)
    {
        <div class="card mt-3">
            <div class="card-body text-center py-5">
                <i class="bi bi-exclamation-circle text-warning" style="font-size:3rem;"></i>
                <h4 class="mt-3">您还未被分配班级和科目</h4>
                <p class="text-muted">请联系管理员为您分配班级和教学科目</p>
            </div>
        </div>
    }
</div>

<!-- 公告对话框 -->
<div class="modal fade" id="annModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning bg-opacity-10">
                <h5 class="modal-title"><i class="bi bi-megaphone-fill me-2"></i>公告</h5>
            </div>
            <div class="modal-body">
                <h6 id="annTitle" class="fw-bold mb-3"></h6>
                <p id="annContent" class="mb-0" style="white-space:pre-wrap"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="annClose">关闭</button>
                <button type="button" class="btn btn-primary" id="annMarkRead"><i class="bi bi-check2 me-1"></i>已阅读</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (myClass != null)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
        <script>
            var genderLabels = @Html.Raw(ViewBag.GenderLabels ?? "[]");
            var genderData = @Html.Raw(ViewBag.GenderData ?? "[]");
            if (genderLabels.length > 0 && genderData.length > 0) {
                new Chart(document.getElementById('genderChart'), {
                    type: 'doughnut',
                    data: {
                        labels: genderLabels,
                        datasets: [{
                            data: genderData,
                            backgroundColor: ['#0d6efd', '#dc3545']
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });
            }
        </script>
    }

    <script>
        // 公告弹窗
        var annModalEl = document.getElementById('annModal');
        var annModal = annModalEl ? new bootstrap.Modal(annModalEl, { backdrop: 'static', keyboard: false }) : null;

        $(function() {
            $.get('@Url.Action("GetUnread", "Home")', function(data) {
                if (data && data.length > 0) {
                    showNextAnnouncement(data, 0);
                }
            });
        });

        function showNextAnnouncement(list, index) {
            if (index >= list.length || !annModal) return;
            var item = list[index];
            document.getElementById('annTitle').textContent = item.title;
            document.getElementById('annContent').textContent = item.content;
            annModalEl.dataset.list = JSON.stringify(list);
            annModalEl.dataset.index = index;
            annModal.show();
        }

        document.getElementById('annMarkRead').addEventListener('click', function() {
            var list = JSON.parse(annModalEl.dataset.list || '[]');
            var idx = parseInt(annModalEl.dataset.index || '0');
            var item = list[idx];
            if (!item) return;
            $.post('@Url.Action("MarkAsRead", "Announce")', { announcementId: item.id, __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val() }, function() {
                annModal.hide();
                showNextAnnouncement(list, idx + 1);
            });
        });

        document.getElementById('annClose').addEventListener('click', function() {
            annModal.hide();
        });
    </script>
}