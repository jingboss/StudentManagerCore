{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IpRestriction": {
    "AllowedIPs": "*"
  },
  "Jwt": {
    "SecretKey": "你的密钥（至少32位字符）",
    "Issuer": "StudentManager",
    "Audience": "StudentManagerUsers",
    "ExpireMinutes": "120"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=StudentManagerDB;User Id=root;Password=YOUR_DB_PASSWORD;"
  }
}
