# Docker 环境变量配置（复制为 .env 后修改）
# 安全配置
MSSQL_SA_PASSWORD=YourPassword123!
JWT_KEY=YourSuperSecretKeyThatIsAtLeast32CharactersLong!

# 数据库连接（docker-compose 内部地址）
DB_CONNECTION=Server=sqlserver;Database=StudentManagerDB;User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=True

# 端口映射
WEB_PORT=8080

# JWT 配置
JWT_ISSUER=StudentManagerCore
JWT_AUDIENCE=StudentManagerCore
JWT_EXPIRE_MINUTES=120
